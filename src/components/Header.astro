---
import OriginalResearchLogo from './OriginalResearchLogo.astro';
import LanguagePicker from './LanguagePicker.astro';
import { getNavigation } from '../i18n/navigation';
import { useTranslations } from '../i18n/ui';
import type { Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const navigation = getNavigation(lang);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;
---

<header class="site-header" id="site-header">
  <div class="container site-header-inner">
    <!-- Logo -->
    <a href={lang === 'en' ? '/' : `/${lang}`} class="site-logo" aria-label="Panorama Research Institute - Home" data-no-translate>
      <OriginalResearchLogo />
    </a>

    <!-- Desktop Nav -->
    <nav class="primary-nav" aria-label="Primary navigation">
      {navigation.map((item) => (
        <div class="nav-item" data-mega={item.mega ? 'true' : undefined}>
          {item.mega ? (
            <>
              <button
                class={`nav-trigger${currentPath.includes('/research') || currentPath.includes('/projects') ? ' active' : ''}`}
                aria-haspopup="true"
                aria-expanded="false"
                type="button"
              >
                {item.label}
                <svg class="nav-chevron" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M2 3.5L5 6.5L8 3.5" />
                </svg>
              </button>
              <div class="mega-menu" role="region" aria-label={`${item.label} menu`}>
                <div class="mega-menu-inner">
                  {item.groups?.map((group) => (
                    <div class="mega-col">
                      <div class="mega-col-title">{group.title}</div>
                      {group.links.map((link) => (
                        <a href={link.href} class="mega-link">{link.label}</a>
                      ))}
                    </div>
                  ))}
                </div>
              </div>
            </>
          ) : item.children ? (
            <>
              <button
                class={`nav-trigger${item.href !== '#' && currentPath.startsWith(item.href) ? ' active' : ''}`}
                aria-haspopup="true"
                aria-expanded="false"
                type="button"
              >
                {item.label}
                <svg class="nav-chevron" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M2 3.5L5 6.5L8 3.5" />
                </svg>
              </button>
              <div class="dropdown" role="menu">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class={`dropdown-link${child.external ? ' external' : ''}`}
                    role="menuitem"
                    target={child.external ? '_blank' : undefined}
                    rel={child.external ? 'noopener noreferrer' : undefined}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </>
          ) : (
            <a href={item.href} class={`nav-trigger${currentPath === item.href ? ' active' : ''}`}>{item.label}</a>
          )}
        </div>
      ))}
    </nav>

    <!-- Right -->
    <div class="header-right">
      <a href={lang === 'en' ? '/contact' : `/${lang}/contact`} class="btn btn-primary">{t('btn.contact')}</a>
      <LanguagePicker />
      <button class="menu-toggle" aria-label="Open menu" id="menu-toggle" type="button">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Nav Overlay -->
<div class="mobile-nav" id="mobile-nav" role="dialog" aria-modal="true" aria-label="Navigation menu">
  <div class="mobile-nav-header">
    <a href={lang === 'en' ? '/' : `/${lang}`} class="site-logo" data-no-translate>
      <OriginalResearchLogo />
    </a>
    <button class="mobile-close" id="mobile-close" aria-label="Close menu" type="button">&#x2715;</button>
  </div>

  {navigation.map((item, idx) => (
    <div class="mobile-nav-item">
      {item.children || item.groups ? (
        <>
          <button class="mobile-nav-trigger" data-target={`msub-${idx}`} type="button">
            {item.label}
            <svg width="12" height="12" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M2 3.5L5 6.5L8 3.5" />
            </svg>
          </button>
          <div class="mobile-sub" id={`msub-${idx}`}>
            {item.children?.map((child) => (
              <a href={child.href} target={child.external ? '_blank' : undefined} rel={child.external ? 'noopener noreferrer' : undefined}>
                {child.label}
              </a>
            ))}
            {item.groups?.flatMap((g) => g.links).map((link) => (
              <a href={link.href}>{link.label}</a>
            ))}
          </div>
        </>
      ) : (
        <a href={item.href} class="mobile-nav-trigger" style="display:block;text-align:left;">{item.label}</a>
      )}
    </div>
  ))}

  <div style="margin-top:24px;display:flex;flex-direction:column;gap:12px;">
    <a href={lang === 'en' ? '/contact' : `/${lang}/contact`} class="btn btn-primary" style="width:100%;justify-content:center;">{t('btn.contact')}</a>
    <LanguagePicker variant="inline" />
  </div>
</div>
