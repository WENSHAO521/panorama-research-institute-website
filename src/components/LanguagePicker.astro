---
import { getBasePath, getLangFromUrl, type Lang } from '../i18n/utils';

interface Props {
  variant?: 'dropdown' | 'inline';
}

const { variant = 'dropdown' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const basePath = getBasePath(Astro.url.pathname);

const langs: { code: Lang; label: string }[] = [
  { code: 'en',    label: 'English' },
  { code: 'zh-cn', label: '简体中文' },
  { code: 'zh-tw', label: '繁體中文' },
];

const currentLang = langs.find((l) => l.code === lang) ?? langs[0];
const currentCode = currentLang.code === 'en' ? 'EN' : currentLang.code === 'zh-cn' ? 'CN' : 'TW';
---

{variant === 'inline' ? (
  <div class="lang-inline" role="group" aria-label="Language selection">
    {langs.map((l) => (
      <a
        href={basePath}
        data-language-option={l.code}
        class={`lang-inline-opt${lang === l.code ? ' lang-active' : ''}`}
        aria-current={lang === l.code ? 'true' : undefined}
        hreflang={l.code}
      >
        <span class="lang-inline-name">{l.label}</span>
        <span class="lang-inline-code">{l.code === 'en' ? 'EN' : l.code === 'zh-cn' ? 'CN' : 'TW'}</span>
      </a>
    ))}
  </div>
) : (
  <details class="lang-picker">
    <summary class="lang-trigger" aria-label="Language selection">
      <span class="lang-icon" aria-hidden="true">
        <svg viewBox="0 0 20 20" focusable="false">
          <circle cx="10" cy="10" r="7.25"></circle>
          <path d="M3 10h14"></path>
          <path d="M10 2.75c2 2.05 3 4.47 3 7.25s-1 5.2-3 7.25"></path>
          <path d="M10 2.75C8 4.8 7 7.22 7 10s1 5.2 3 7.25"></path>
        </svg>
      </span>
      <span class="lang-current">{currentLang.label}</span>
      <span class="lang-current-short" aria-hidden="true">{currentCode}</span>
      <span class="lang-chevron" aria-hidden="true"></span>
    </summary>
    <div class="lang-menu" role="menu" aria-label="Language selection">
      {langs.map((l) => (
        <a
          href={basePath}
          data-language-option={l.code}
          class={`lang-opt${lang === l.code ? ' lang-active' : ''}`}
          aria-current={lang === l.code ? 'true' : undefined}
          hreflang={l.code}
          role="menuitem"
        >
          <span class="lang-name">{l.label}</span>
          <span class="lang-code">{l.code === 'en' ? 'EN' : l.code === 'zh-cn' ? 'CN' : 'TW'}</span>
        </a>
      ))}
    </div>
  </details>
)}

<style>
.lang-picker {
  position: relative;
  flex-shrink: 0;
  z-index: 240;
}
.lang-picker[open] .lang-trigger {
  border-color: rgba(55, 90, 107, 0.42);
  background: var(--bg-white);
  box-shadow: 0 8px 22px rgba(31, 35, 38, 0.06);
}
.lang-picker[open] .lang-chevron {
  transform: rotate(225deg);
  margin-top: 4px;
}
.lang-trigger {
  display: inline-flex;
  align-items: center;
  gap: 9px;
  min-height: 40px;
  padding: 0 12px;
  border: 1px solid rgba(31, 35, 38, 0.16);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.88);
  color: var(--text-main);
  cursor: pointer;
  list-style: none;
  transition: border-color 0.15s ease, background 0.15s ease, transform 0.12s ease, box-shadow 0.15s ease;
  white-space: nowrap;
}
.lang-trigger::-webkit-details-marker {
  display: none;
}
.lang-trigger:hover {
  border-color: rgba(31, 35, 38, 0.34);
  background: var(--bg-white);
}
.lang-trigger:active {
  transform: translateY(1px);
}
.lang-trigger:focus-visible {
  outline: 2px solid rgba(31, 35, 38, 0.22);
  outline-offset: 2px;
}
.lang-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 18px;
  height: 18px;
  color: var(--accent-steel);
}
.lang-icon svg {
  width: 18px;
  height: 18px;
  fill: none;
  stroke: currentColor;
  stroke-width: 1.35;
  stroke-linecap: round;
  stroke-linejoin: round;
}
.lang-current {
  font-size: 13px;
  font-weight: 600;
  line-height: 1;
}
.lang-current-short {
  display: none;
  font-family: var(--font-mono);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.04em;
  line-height: 1;
}
.lang-chevron {
  width: 7px;
  height: 7px;
  border-right: 1.5px solid currentColor;
  border-bottom: 1.5px solid currentColor;
  transform: rotate(45deg);
  margin-top: -3px;
  transition: transform 0.15s ease, margin-top 0.15s ease;
}
.lang-menu {
  position: absolute;
  top: calc(100% + 10px);
  right: 0;
  min-width: 190px;
  padding: 8px;
  background: var(--bg-white);
  border: 1px solid var(--border-light);
  border-radius: 10px;
  box-shadow: 0 18px 42px rgba(31, 35, 38, 0.12), 0 4px 12px rgba(31, 35, 38, 0.05);
}
.lang-opt {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  min-height: 38px;
  padding: 9px 11px;
  border-radius: 7px;
  color: var(--text-main);
  font-size: 13.5px;
  font-weight: 500;
  line-height: 1.35;
  transition: background 0.1s ease, color 0.1s ease;
  white-space: nowrap;
}
.lang-opt:hover,
.lang-active {
  background: var(--bg-soft);
}
.lang-code {
  min-width: 24px;
  color: var(--text-muted);
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: 0.04em;
  text-align: right;
}
.lang-active .lang-code {
  color: var(--accent-steel);
}
.lang-opt.lang-active::after {
  content: "";
  width: 5px;
  height: 5px;
  background: var(--accent-steel);
  border-radius: 999px;
  margin-left: -8px;
}

@media (max-width: 768px) {
  .lang-picker {
    width: auto;
  }
  .lang-trigger {
    min-height: 38px;
    padding: 0 10px;
    justify-content: center;
  }
  .lang-menu {
    min-width: 176px;
    max-width: calc(100vw - 32px);
  }
  .lang-current {
    display: none;
  }
  .lang-current-short {
    display: inline-flex;
  }
}

.lang-inline {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6px;
  width: 100%;
  padding: 6px;
  border: 1px solid var(--border-light);
  border-radius: 10px;
  background: var(--bg-soft);
}
.lang-inline-opt {
  display: flex;
  min-height: 42px;
  align-items: center;
  justify-content: center;
  gap: 7px;
  border-radius: 7px;
  color: var(--text-secondary);
  font-size: 13px;
  font-weight: 600;
  line-height: 1;
  transition: background 0.12s ease, color 0.12s ease, box-shadow 0.12s ease;
  white-space: nowrap;
}
.lang-inline-opt:hover,
.lang-inline-opt.lang-active {
  background: var(--bg-white);
  color: var(--text-main);
  box-shadow: 0 1px 3px rgba(31, 35, 38, 0.08);
}
.lang-inline-code {
  color: var(--text-muted);
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.04em;
}

@media (max-width: 420px) {
  .lang-inline-opt {
    gap: 0;
    font-size: 12.5px;
    padding: 0 4px;
  }
  .lang-inline-code {
    display: none;
  }
}
</style>
