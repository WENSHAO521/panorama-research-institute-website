---
interface Props {
  variant?: 'dark' | 'light';
  size?: 'sm' | 'md' | 'lg';
}
const { variant = 'dark', size = 'md' } = Astro.props;
const heights   = { sm: '36px', md: '44px', lg: '56px' };
const src = '/research-institute-logo.svg';
---

<span class={`brand-logo-frame brand-logo-frame-${variant}`} style={`height:${heights[size]};`}>
  <img
    src={src}
    alt="Panorama Research Institute"
    class="brand-logo-img"
    decoding="async"
  />
</span>

<style>
.brand-logo-frame {
  display: block;
  width: 150px;
  overflow: hidden;
}
.brand-logo-img {
  display: block;
  height: 100%;
  width: auto;
  max-width: none;
  transform: translateX(-7px);
}
.brand-logo-frame-light .brand-logo-img {
  filter: invert(1) grayscale(1) brightness(2.2);
  opacity: 0.92;
}
</style>
