---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { clientTranslations } from '../i18n/clientTranslations';
import { clientTranslationsExtra } from '../i18n/clientTranslationsExtra';
import { getBasePath, type Lang } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  lang?: Lang;
}

const {
  title = 'Panorama Research Institute',
  description = 'Panorama Research Institute is an independent academic platform and internal research and academic development division of Panorama Scholarly Group.',
  ogImage,
  lang = 'en',
} = Astro.props;

const canonicalURL = new URL(getBasePath(Astro.url.pathname), Astro.site ?? 'https://research.panorama-sg.com');
const fullTitle = title === 'Panorama Research Institute'
  ? title
  : `${title} | Panorama Research Institute`;

const phraseTranslations = {
  'zh-cn': {
    ...clientTranslations['zh-cn'],
    ...clientTranslationsExtra['zh-cn'],
  },
  'zh-tw': {
    ...clientTranslations['zh-tw'],
    ...clientTranslationsExtra['zh-tw'],
  },
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {lang !== 'en' && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <link rel="alternate" hreflang={lang} href={canonicalURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <Header lang={lang} />
    <main id="main-content">
      <slot />
    </main>
    <Footer lang={lang} />
    <script define:vars={{ phraseTranslations }}>
      const LANGUAGE_STORAGE_KEY = 'panorama-language';
      const SUPPORTED_LANGUAGES = ['en', 'zh-cn', 'zh-tw'];
      const ORIGINAL_TEXT = new WeakMap();
      const ORIGINAL_ATTRIBUTES = new WeakMap();
      const PHRASE_TRANSLATIONS = phraseTranslations;

      function getPathLanguage(pathname) {
        const firstSegment = pathname.split('/')[1];
        return SUPPORTED_LANGUAGES.includes(firstSegment) && firstSegment !== 'en' ? firstSegment : null;
      }

      function getBasePath(pathname) {
        const pathLanguage = getPathLanguage(pathname);
        if (!pathLanguage) return pathname || '/';
        const basePath = pathname.slice(pathLanguage.length + 1);
        return basePath || '/';
      }

      function getStoredLanguage() {
        const stored = window.localStorage.getItem(LANGUAGE_STORAGE_KEY);
        return SUPPORTED_LANGUAGES.includes(stored) ? stored : 'en';
      }

      function setStoredLanguage(lang) {
        window.localStorage.setItem(LANGUAGE_STORAGE_KEY, lang);
      }

      function closeMobileNav() {
        const mobileNav = document.getElementById('mobile-nav');
        mobileNav?.classList.remove('open');
        document.body.style.overflow = '';
      }

      function updateLanguagePicker(lang) {
        document.querySelectorAll('[data-language-option]').forEach((node) => {
          const link = node;
          const optionLang = link.getAttribute('data-language-option');
          const isActive = optionLang === lang;
          link.classList.toggle('lang-active', isActive);
          if (isActive) {
            link.setAttribute('aria-current', 'true');
          } else {
            link.removeAttribute('aria-current');
          }
        });

        const activeOption = document.querySelector(`[data-language-option="${lang}"]`);
        const activeLabel = activeOption?.querySelector('.lang-name')?.textContent?.trim()
          || activeOption?.textContent?.trim();
        const activeCode = activeOption?.querySelector('.lang-code, .lang-inline-code')?.textContent?.trim()
          || (lang === 'en' ? 'EN' : lang === 'zh-cn' ? 'CN' : 'TW');
        document.querySelectorAll('.lang-current').forEach((node) => {
          if (activeLabel) node.textContent = activeLabel;
        });
        document.querySelectorAll('.lang-current-short').forEach((node) => {
          node.textContent = activeCode;
        });
      }

      function getTranslationRoots() {
        return [
          document.getElementById('site-header'),
          document.getElementById('mobile-nav'),
          document.getElementById('main-content'),
          document.querySelector('.site-footer'),
        ].filter(Boolean);
      }

      function shouldSkipTranslationNode(node) {
        const element = node instanceof Element ? node : node.parentElement;
        return Boolean(element?.closest('[data-no-translate], .site-logo'));
      }

      function captureOriginalContent() {
        const roots = [
          document.getElementById('site-header'),
          document.getElementById('mobile-nav'),
          document.getElementById('main-content'),
          document.querySelector('.site-footer'),
        ].filter(Boolean);

        roots.forEach((root) => {
          const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
            acceptNode(node) {
              const parent = node.parentElement;
              if (!parent || ['SCRIPT', 'STYLE', 'NOSCRIPT', 'TEMPLATE'].includes(parent.tagName)) {
                return NodeFilter.FILTER_REJECT;
              }
              if (shouldSkipTranslationNode(node)) return NodeFilter.FILTER_REJECT;
              return node.textContent && node.textContent.trim()
                ? NodeFilter.FILTER_ACCEPT
                : NodeFilter.FILTER_REJECT;
            },
          });

          const nodes = [];
          while (walker.nextNode()) nodes.push(walker.currentNode);

          nodes.forEach((node) => {
            if (!ORIGINAL_TEXT.has(node)) {
              ORIGINAL_TEXT.set(node, node.textContent || '');
            }
          });

          root.querySelectorAll('[aria-label], [alt], [title], [placeholder]').forEach((element) => {
            if (shouldSkipTranslationNode(element)) return;
            if (!ORIGINAL_ATTRIBUTES.has(element)) ORIGINAL_ATTRIBUTES.set(element, {});
            const originals = ORIGINAL_ATTRIBUTES.get(element);
            ['aria-label', 'alt', 'title', 'placeholder'].forEach((attribute) => {
              if (!(attribute in originals)) {
                const value = element.getAttribute(attribute);
                if (value !== null) originals[attribute] = value;
              }
            });
          });
        });
      }

      function translateTextValue(originalValue, dictionary) {
        const trimmed = originalValue.trim();
        if (!trimmed) return originalValue;
        const translated = dictionary?.[trimmed];
        return translated ? originalValue.replace(trimmed, translated) : originalValue;
      }

      function applyPhraseTranslations(lang) {
        captureOriginalContent();
        const dictionary = PHRASE_TRANSLATIONS[lang];

        getTranslationRoots().forEach((root) => {
          const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
            acceptNode(node) {
              const parent = node.parentElement;
              if (!parent || ['SCRIPT', 'STYLE', 'NOSCRIPT', 'TEMPLATE'].includes(parent.tagName)) {
                return NodeFilter.FILTER_REJECT;
              }
              if (shouldSkipTranslationNode(node)) return NodeFilter.FILTER_REJECT;
              return ORIGINAL_TEXT.has(node) || (node.textContent && node.textContent.trim())
                ? NodeFilter.FILTER_ACCEPT
                : NodeFilter.FILTER_REJECT;
            },
          });

          const nodes = [];
          while (walker.nextNode()) nodes.push(walker.currentNode);

          nodes.forEach((node) => {
            const originalValue = ORIGINAL_TEXT.get(node) ?? node.textContent ?? '';
            node.textContent = lang === 'en'
              ? originalValue
              : translateTextValue(originalValue, dictionary);
          });

          root.querySelectorAll('[aria-label], [alt], [title], [placeholder]').forEach((element) => {
            if (shouldSkipTranslationNode(element)) return;
            const originals = ORIGINAL_ATTRIBUTES.get(element);
            if (!originals) return;
            ['aria-label', 'alt', 'title', 'placeholder'].forEach((attribute) => {
              if (!(attribute in originals)) return;
              const originalValue = originals[attribute];
              element.setAttribute(attribute, lang === 'en'
                ? originalValue
                : translateTextValue(originalValue, dictionary));
            });
          });
        });
      }

      function rewriteInternalLinks(activeLang) {
        const origin = window.location.origin;

        document.querySelectorAll('a[href]').forEach((anchor) => {
          const href = anchor.getAttribute('href');
          if (!href || href.startsWith('mailto:') || href.startsWith('tel:') || href.startsWith('#')) return;

          let url;
          try {
            url = new URL(href, origin);
          } catch {
            return;
          }

          if (url.origin !== origin) return;

          const basePath = getBasePath(url.pathname);
          const cleanHref = `${basePath}${url.search}${url.hash}`;
          anchor.setAttribute('href', cleanHref);

        });

        document.querySelectorAll('[data-language-option]').forEach((node) => {
          node.setAttribute('href', getBasePath(window.location.pathname));
        });

        updateLanguagePicker(activeLang);
      }

      async function applyLanguage(lang, options = {}) {
        const shouldPersist = options.persist !== false;
        const shouldScroll = options.scroll === true;

        if (shouldPersist) setStoredLanguage(lang);

        document.documentElement.lang = lang;
        closeMobileNav();
        rewriteInternalLinks(lang);
        applyPhraseTranslations(lang);
        if (shouldScroll) window.scrollTo({ top: 0, behavior: 'instant' });
      }

      function normalizeInitialUrl() {
        const pathLanguage = getPathLanguage(window.location.pathname);
        if (!pathLanguage) return null;

        const basePath = getBasePath(window.location.pathname);
        setStoredLanguage(pathLanguage);
        window.location.replace(`${basePath}${window.location.search}${window.location.hash}`);
        return pathLanguage;
      }

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        const languageLink = target.closest('[data-language-option]');
        if (languageLink) {
          event.preventDefault();
          const lang = languageLink.getAttribute('data-language-option') || 'en';
          document.querySelectorAll('.lang-picker[open]').forEach((picker) => picker.removeAttribute('open'));
          applyLanguage(lang);
          return;
        }

        const menuToggle = target.closest('#menu-toggle');
        if (menuToggle) {
          const mobileNav = document.getElementById('mobile-nav');
          mobileNav?.classList.add('open');
          document.body.style.overflow = 'hidden';
          return;
        }

        const mobileClose = target.closest('#mobile-close');
        if (mobileClose) {
          closeMobileNav();
          return;
        }

        const mobileTrigger = target.closest('.mobile-nav-trigger[data-target]');
        if (mobileTrigger) {
          const targetId = mobileTrigger.getAttribute('data-target');
          if (targetId) document.getElementById(targetId)?.classList.toggle('open');
          return;
        }

        const dropdownTrigger = target.closest('.nav-trigger[aria-haspopup]');
        if (dropdownTrigger) {
          dropdownTrigger.setAttribute('aria-expanded', String(dropdownTrigger.getAttribute('aria-expanded') !== 'true'));
          return;
        }

        const link = target.closest('a[href]');
        if (!link || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
        if (link.target || link.hasAttribute('download')) return;

        const href = link.getAttribute('href');
        if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) return;

        const url = new URL(href, window.location.origin);
        if (url.origin !== window.location.origin) return;

        link.setAttribute('href', `${getBasePath(url.pathname)}${url.search}${url.hash}`);
      });

      document.addEventListener('focusout', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const navItem = target.closest('.nav-item');
        if (!navItem || navItem.contains(event.relatedTarget)) return;
        navItem.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'false');
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeMobileNav();
      });

      window.addEventListener('popstate', () => {
        const lang = getStoredLanguage();
        if (lang !== 'en') applyLanguage(lang, { persist: false });
      });

      const redirectedLanguage = normalizeInitialUrl();
      if (!redirectedLanguage) {
        const initialLanguage = getStoredLanguage();
        captureOriginalContent();
        rewriteInternalLinks(initialLanguage);
        applyPhraseTranslations(initialLanguage);
        if (initialLanguage !== 'en') {
          applyLanguage(initialLanguage, { persist: false });
        }
      }
    </script>
  </body>
</html>
