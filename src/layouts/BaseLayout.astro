---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { getBasePath, type Lang } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  lang?: Lang;
}

const {
  title = 'Panorama Research Institute',
  description = 'Panorama Research Institute is an independent academic platform and internal research and academic development division of Panorama Scholarly Group.',
  ogImage,
  lang = 'en',
} = Astro.props;

const canonicalURL = new URL(getBasePath(Astro.url.pathname), Astro.site ?? 'https://research.panorama-sg.com');
const fullTitle = title === 'Panorama Research Institute'
  ? title
  : `${title} | Panorama Research Institute`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {lang !== 'en' && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <link rel="alternate" hreflang={lang} href={canonicalURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <Header lang={lang} />
    <main id="main-content">
      <slot />
