---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="Submit an Inquiry" description="General collaboration inquiry form for Panorama Research Institute.">
  <PageHero
    title="Submit an Inquiry"
    description="Use this form for general collaboration inquiries, or navigate to a specific form below if your inquiry relates to a particular type of collaboration."
    breadcrumbs={[{ label: "Collaboration", href: "/collaboration" }, { label: "Submit an Inquiry" }]}
  />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 2fr;gap:64px;align-items:start;">
        <div>
          <div class="section-label">Specific Forms</div>
          <p style="font-size:14px;color:var(--text-muted);line-height:1.6;margin-top:8px;margin-bottom:16px;">
            If your inquiry relates to a specific type of collaboration, use the dedicated form:
          </p>
          <div style="display:flex;flex-direction:column;gap:6px;">
            {[
              { label:"Research Project Proposal",     href:"/collaboration/research-project-proposal" },
              { label:"Edited Volume Proposal",        href:"/collaboration/edited-volume-proposal" },
              { label:"Special Issue Proposal",        href:"/collaboration/special-issue-proposal" },
              { label:"Visiting Scholar Application",  href:"/collaboration/visiting-scholar-application" },
              { label:"Research Fellow Application",   href:"/collaboration/research-fellow-application" },
              { label:"Event Cooperation",             href:"/collaboration/event-cooperation" },
              { label:"Institutional Cooperation",     href:"/collaboration/institutional-cooperation" },
            ].map((item) => (
              <a href={item.href} style="display:block;font-size:13.5px;color:var(--accent-steel);padding:8px 0;border-bottom:1px solid var(--border-light);">{item.label} &rarr;</a>
            ))}
          </div>
        </div>
        <div>
          <h2 style="font-family:var(--font-serif);font-size:24px;color:var(--text-main);margin-bottom:16px;font-weight:400;">General Collaboration Inquiry</h2>
          <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:32px;">
            Use this form if your inquiry does not fit neatly into one of the specific collaboration types listed, or if you would like to discuss collaboration possibilities with the Institute before committing to a specific form. The Collaboration Office will respond within 10 working days.
          </p>

          <form style="display:flex;flex-direction:column;gap:0;" action="#" method="post">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;">
              {[
                { label:"Your Name",       id:"inq-name",  type:"text",  placeholder:"Full name" },
                { label:"Email Address",   id:"inq-email", type:"email", placeholder:"your@email.com" },
                { label:"Organization",    id:"inq-org",   type:"text",  placeholder:"Institution or organization (if applicable)" },
                { label:"Country",         id:"inq-country",type:"text", placeholder:"Country" },
              ].map((f) => (
                <div style="padding:12px;border:1px solid var(--border-light);margin:-0.5px;">
                  <label for={f.id} style="display:block;font-size:11px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:6px;">{f.label}</label>
                  <input id={f.id} name={f.id} type={f.type} placeholder={f.placeholder} class="form-input" style="width:100%;" />
                </div>
              ))}
            </div>
            <div style="padding:12px;border:1px solid var(--border-light);margin-top:-0.5px;">
              <label for="inq-type" style="display:block;font-size:11px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:6px;">Type of Inquiry</label>
              <select id="inq-type" name="inq-type" class="form-input" style="width:100%;">
                <option value="">Select type of inquiry...</option>
                <option>Institutional cooperation / MoU</option>
                <option>Research collaboration</option>
                <option>Publication collaboration</option>
                <option>Event cooperation</option>
                <option>Fellowship / scholar program inquiry</option>
                <option>Media / press inquiry</option>
                <option>General inquiry</option>
              </select>
            </div>
            <div style="padding:12px;border:1px solid var(--border-light);margin-top:-0.5px;">
              <label for="inq-msg" style="display:block;font-size:11px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:6px;">Your Message</label>
              <textarea id="inq-msg" name="inq-msg" rows="8" placeholder="Please describe your inquiry, proposed collaboration, or question. Include as much relevant detail as possible so the Collaboration Office can respond helpfully." class="form-input" style="width:100%;resize:vertical;"></textarea>
            </div>
            <div style="padding:12px;border:1px solid var(--border-light);margin-top:-0.5px;display:flex;gap:10px;align-items:flex-start;">
              <input type="checkbox" id="inq-consent" name="inq-consent" style="margin-top:3px;flex-shrink:0;" />
              <label for="inq-consent" style="font-size:13.5px;color:var(--text-secondary);line-height:1.6;">I consent to Panorama Research Institute using the information provided to respond to this inquiry and to send relevant institutional communications. I may withdraw this consent at any time.</label>
            </div>
            <div style="padding:12px;border:1px solid var(--border-light);margin-top:-0.5px;">
              <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">Submit Inquiry</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 900px) {
  div[style*="grid-template-columns:1fr 2fr"] { display: block !important; }
  div[style*="grid-template-columns:1fr 1fr"] { display: block !important; }
}
</style>
