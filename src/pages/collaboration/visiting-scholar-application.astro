---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="Visiting Scholar Application" description="Apply for the Panorama Research Institute Visiting Scholar Program.">
  <PageHero
    title="Visiting Scholar Application"
    description="Apply to affiliate with Panorama Research Institute as a Visiting Scholar for a period of 3–12 months. The Visiting Scholar Program is open to established researchers with a PhD or equivalent qualification."
    breadcrumbs={[{ label: "Collaboration", href: "/collaboration" }, { label: "Visiting Scholar Application" }]}
  />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 2fr;gap:64px;align-items:start;">
        <div>
          <div class="section-label">Program Details</div>
          <div style="display:flex;flex-direction:column;gap:16px;margin-top:8px;">
            {[
              { label:"Duration",        value:"3–12 months" },
              { label:"Format",          value:"Remote or in-person" },
              { label:"Eligibility",     value:"PhD or equivalent, established researcher" },
              { label:"Application",     value:"Rolling (no fixed deadline)" },
              { label:"Response Time",   value:"Within 15 working days" },
              { label:"Contact",         value:"scholars@panorama-sg.com" },
            ].map((item) => (
              <div>
                <div style="font-size:11px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:4px;">{item.label}</div>
                <div style="font-size:14.5px;color:var(--text-main);">{item.value}</div>
              </div>
            ))}
          </div>
          <div style="margin-top:20px;">
            <a href="/people/visiting-scholars" class="btn btn-secondary" style="width:100%;justify-content:center;">About the Program</a>
          </div>
        </div>
        <div>
          <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:32px;">
            Use this form to apply to affiliate with Panorama Research Institute as a Visiting Scholar. Applications are reviewed by the Scholar Program Coordinator and the relevant Research Center Director. Successful applicants will be contacted to discuss the terms and scope of the visiting affiliation.
          </p>

          <form style="display:flex;flex-direction:column;gap:0;" action="#" method="post">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;">
              {[
                { label:"Full Name",      id:"vs-name",    type:"text",  placeholder:"Full name" },
                { label:"Email Address",  id:"vs-email",   type:"email", placeholder:"your@email.com" },
                { label:"Current Institution", id:"vs-inst", type:"text", placeholder:"University or research institution" },
                { label:"Position/Title", id:"vs-title",   type:"text",  placeholder:"e.g. Senior Lecturer" },
              ].map((f) => (
                <div style="padding:12px;border:1px solid var(--border-light);margin:-0.5px;">
                  <label for={f.id} style="display:block;font-size:11px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:6px;">{f.label}</label>
                  <input id={f.id} name={f.id} type={f.type} placeholder={f.placeholder} class="form-input" style="width:100%;" />
                </div>
              ))}
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;margin-top:-0.5px;">
              {[
                { label:"Proposed Start Date", id:"vs-start", type:"text", placeholder:"e.g. January 2026" },
                { label:"Proposed Duration",   id:"vs-dur",   type:"text", placeholder:"e.g. 6 months" },
              ].map((f) => (
                <div style="padding:12px;border:1px solid var(--border-light);margin:-0.5px;">
                  <label for={f.id} style="display:block;font-size:11px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:6px;">{f.label}</label>
                  <input id={f.id} name={f.id} type={f.type} placeholder={f.placeholder} class="form-input" style="width:100%;" />
                </div>
              ))}
            </div>
            <div style="padding:12px;border:1px solid var(--border-light);margin-top:-0.5px;">
              <label for="vs-center" style="display:block;font-size:11px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:6px;">Preferred Research Center Host</label>
              <select id="vs-center" name="vs-center" class="form-input" style="width:100%;">
                <option value="">Select a research center...</option>
                <option>Center for Scholarly Publishing Studies</option>
                <option>Center for Scholarly Indexing and Evaluation</option>
                <option>Center for Policy and Social Research</option>
                <option>Center for AI and Future Society</option>
                <option>Open to suggestion</option>
              </select>
            </div>
            <div style="padding:12px;border:1px solid var(--border-light);margin-top:-0.5px;">
              <label for="vs-research" style="display:block;font-size:11px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:6px;">Research Plan and Objectives (300–800 words)</label>
              <textarea id="vs-research" name="vs-research" rows="8" placeholder="Describe the research you intend to pursue during the visiting period, its relation to the Institute's research program, and any specific collaboration or output plans." class="form-input" style="width:100%;resize:vertical;"></textarea>
            </div>
            <div style="padding:12px;border:1px solid var(--border-light);margin-top:-0.5px;">
              <label for="vs-cv" style="display:block;font-size:11px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:6px;">Academic Profile / CV Summary (up to 400 words)</label>
              <textarea id="vs-cv" name="vs-cv" rows="5" placeholder="Academic bio, key publications, and any other relevant experience." class="form-input" style="width:100%;resize:vertical;"></textarea>
            </div>
            <div style="padding:12px;border:1px solid var(--border-light);margin-top:-0.5px;display:flex;gap:10px;align-items:flex-start;">
              <input type="checkbox" id="vs-consent" name="vs-consent" style="margin-top:3px;flex-shrink:0;" />
              <label for="vs-consent" style="font-size:13.5px;color:var(--text-secondary);line-height:1.6;">I confirm the information above is accurate and that I am genuinely interested in pursuing the research described during the proposed visiting period.</label>
            </div>
            <div style="padding:12px;border:1px solid var(--border-light);margin-top:-0.5px;">
              <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">Submit Application</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 900px) {
  div[style*="grid-template-columns:1fr 2fr"] { display: block !important; }
  div[style*="grid-template-columns:1fr 1fr"] { display: block !important; }
}
</style>
