---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="Events Archive" description="Past events organized by Panorama Research Institute.">
  <PageHero
    title="Events Archive"
    description="Archive of past events organized or co-organized by Panorama Research Institute, including conferences, seminars, workshops, and training programs."
    breadcrumbs={[{ label: "Events", href: "/events" }, { label: "Archive" }]}
  />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div style="max-width:720px;">
        <div class="statement-box" style="margin-bottom:40px;">
          <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-muted);margin-bottom:10px;">Archive Notice</div>
          <p style="font-size:15.5px;line-height:1.8;color:var(--text-secondary);margin:0;">
            Panorama Research Institute was established in 2024 and is currently in its foundational phase. No events have yet been completed and archived. This page will be updated following the Institute's inaugural events.
          </p>
        </div>

        <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:24px;">
          Completed events are archived here with records of the event date, program, participants, and any outputs produced — including proceedings, summaries, or recordings where available.
        </p>

        <div style="display:flex;gap:10px;flex-wrap:wrap;">
          <a href="/events" class="btn btn-primary">Upcoming Events</a>
          <a href="/events/conferences" class="btn btn-secondary">Conferences</a>
          <a href="/events/seminars" class="btn btn-secondary">Seminars</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
