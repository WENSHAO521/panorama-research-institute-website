---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="Calls for Chapters" description="Open calls for chapter submissions for Panorama Research Institute edited volumes.">
  <PageHero
    title="Calls for Chapters"
    description="Open calls for chapter submissions for edited volumes published in association with Panorama Research Institute. Contribute original research to collaborative scholarly volumes on the Institute's research themes."
    breadcrumbs={[{ label: "Events", href: "/events" }, { label: "Calls for Chapters" }]}
  />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div style="max-width:860px;">
        <div style="padding:32px;background:var(--bg-soft);border:1px solid var(--border-light);margin-bottom:48px;">
          <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-muted);margin-bottom:12px;">Current Status</div>
          <p style="font-size:15.5px;color:var(--text-secondary);line-height:1.7;margin-bottom:16px;">
            No calls for chapters are currently open. Panorama Research Institute's edited volume program is in its planning stage, with the first volume anticipated to be announced in 2026.
          </p>
          <p style="font-size:14px;color:var(--text-muted);margin:0;line-height:1.6;">
            If you are interested in proposing an edited volume, please see the <a href="/collaboration/edited-volume-proposal" style="color:var(--accent-steel);">edited volume proposal</a> page.
          </p>
        </div>

        <h2 style="font-family:var(--font-serif);font-size:24px;color:var(--text-main);margin-bottom:16px;font-weight:400;">About the Edited Volume Program</h2>
        <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:20px;">
          Panorama Research Institute is developing a program of edited academic volumes on themes central to its research program. Edited volumes bring together original chapters from multiple scholars, providing a comprehensive treatment of a research theme that no single author could produce alone.
        </p>
        <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:32px;">
          When a call for chapters is open, chapter contributors do not need to be formally affiliated with the Institute. Submissions must fall within the scope of the volume, meet the Institute's publication standards, and be submitted by the stated deadline. Each call includes specific guidance on the expected chapter length, format, review process, and publication timeline.
        </p>

        <h2 style="font-family:var(--font-serif);font-size:22px;color:var(--text-main);margin-bottom:16px;font-weight:400;">Planned Volumes</h2>
        <div style="display:flex;flex-direction:column;gap:0;border:1px solid var(--border-light);margin-bottom:40px;">
          {[
            { title:"Open Access and Scholarly Communication in Asia-Pacific", theme:"Scholarly Publishing", year:"2026 (planned)" },
            { title:"Journal Evaluation Beyond the Impact Factor: Alternative Frameworks and Approaches", theme:"Scholarly Indexing and Evaluation", year:"2026 (planned)" },
          ].map((item) => (
            <div style="padding:24px;border-bottom:1px solid var(--border-light);">
              <div style="font-family:var(--font-mono);font-size:11px;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-muted);margin-bottom:8px;">{item.theme} &bull; {item.year}</div>
              <h3 style="font-family:var(--font-serif);font-size:18px;color:var(--text-main);font-weight:400;">{item.title}</h3>
            </div>
          ))}
        </div>

        <div style="display:flex;gap:10px;flex-wrap:wrap;">
          <a href="/collaboration/edited-volume-proposal" class="btn btn-primary">Propose a Volume</a>
          <a href="/publications/edited-volumes" class="btn btn-secondary">Edited Volumes</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
