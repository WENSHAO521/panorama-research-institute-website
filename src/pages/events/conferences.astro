---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="Conferences" description="Academic conferences organized or co-organized by Panorama Research Institute.">
  <PageHero
    title="Conferences"
    description="Academic conferences organized and co-organized by Panorama Research Institute, bringing together scholars, policymakers, and practitioners in the Institute's research areas."
    breadcrumbs={[{ label: "Events", href: "/events" }, { label: "Conferences" }]}
  />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div style="max-width:860px;">
        <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:40px;">
          Panorama Research Institute plans to develop an international conference program centered on the Institute's core research themes of scholarly publishing, journal evaluation, academic policy, and emerging digital futures. The first Institute-organized conference is planned for 2026.
        </p>

        <div style="margin-bottom:48px;padding:32px;background:var(--bg-soft);border:1px solid var(--border-light);">
          <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-muted);margin-bottom:12px;">Upcoming — Planning Stage</div>
          <h2 style="font-family:var(--font-serif);font-size:24px;color:var(--text-main);margin-bottom:12px;font-weight:400;">First Panorama International Conference on Scholarly Communication</h2>
          <p style="font-size:15px;color:var(--text-secondary);line-height:1.7;margin-bottom:20px;">
            The Institute is in the early planning stage for its inaugural international conference on scholarly communication, academic publishing, and open science. The conference will bring together researchers, editors, publishers, librarians, and policymakers from across the Asia-Pacific region and beyond.
          </p>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:20px;">
            {[
              { label:"Planned Date", value:"2026 (TBD)" },
              { label:"Format", value:"In-person + online (hybrid)" },
              { label:"Location", value:"To be announced" },
            ].map((item) => (
              <div>
                <div style="font-size:11px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:4px;">{item.label}</div>
                <div style="font-size:14.5px;color:var(--text-main);">{item.value}</div>
              </div>
            ))}
          </div>
          <a href="/events/calls-for-papers" class="btn btn-primary">Register Interest</a>
        </div>

        <h2 style="font-family:var(--font-serif);font-size:22px;color:var(--text-main);margin-bottom:16px;font-weight:400;">Conference Co-organization</h2>
        <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:20px;">
          The Institute is open to co-organizing academic conferences with partner institutions. Co-organized conferences enable the Institute to contribute its research expertise and institutional support to events that align with its mission, while supporting the broader scholarly community. Inquiries regarding conference co-organization are welcome through the Collaboration Office.
        </p>
        <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:24px;">
          <a href="/collaboration/event-cooperation" class="btn btn-primary">Co-organize a Conference</a>
          <a href="/events/calls-for-papers" class="btn btn-secondary">Calls for Papers</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 768px) {
  div[style*="grid-template-columns:repeat(3,1fr)"] { display: block !important; }
}
</style>
