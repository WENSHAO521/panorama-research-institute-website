---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="Academic Seminars" description="Seminar series organized by Panorama Research Institute.">
  <PageHero
    title="Academic Seminars"
    description="Academic seminars organized by Panorama Research Institute, providing a regular forum for the presentation and discussion of research in the Institute's focus areas."
    breadcrumbs={[{ label: "Events", href: "/events" }, { label: "Seminars" }]}
  />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 2fr;gap:64px;align-items:start;">
        <div>
          <div class="section-label">Seminar Program</div>
          <div style="display:flex;flex-direction:column;gap:16px;margin-top:8px;">
            {[
              { label: "Frequency",   value: "Quarterly (planned)" },
              { label: "Format",      value: "Online and in-person" },
              { label: "Duration",    value: "90 minutes per session" },
              { label: "Open to",     value: "All interested scholars and practitioners" },
              { label: "Language",    value: "English (primary)" },
              { label: "Contact",     value: "events@panorama-sg.com" },
            ].map((item) => (
              <div>
                <div style="font-size:11px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:4px;">{item.label}</div>
                <div style="font-size:14.5px;color:var(--text-main);">{item.value}</div>
              </div>
            ))}
          </div>
          <div style="margin-top:28px;">
            <a href="/collaboration/event-cooperation" class="btn btn-primary" style="width:100%;justify-content:center;">Propose a Speaker</a>
          </div>
        </div>
        <div>
          <h2 style="font-family:var(--font-serif);font-size:24px;color:var(--text-main);margin-bottom:16px;font-weight:400;">Panorama Research Seminar Series</h2>
          <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:20px;">
            The Panorama Research Seminar Series is a planned program of regular academic seminars providing a forum for researchers to present work in the Institute's focus areas. The seminar series is designed to support scholarly exchange, introduce new research to the community, and foster connections among researchers working on related questions.
          </p>
          <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:32px;">
            Seminars will feature invited presentations from scholars affiliated with the Institute and from external researchers. Each session will include a presentation followed by a structured discussion period. Seminars will be held in hybrid format, accessible to remote participants globally.
          </p>

          <div style="background:var(--bg-soft);border:1px solid var(--border-light);padding:24px;margin-bottom:32px;">
            <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-muted);margin-bottom:8px;">Program Status</div>
            <p style="font-size:14.5px;color:var(--text-secondary);margin:0;line-height:1.7;">
              The Panorama Research Seminar Series is planned to launch in 2025. Announcements for the inaugural session will be made through the Institute's website and mailing list. Register your interest to receive notifications when the program is announced.
            </p>
          </div>

          <h3 style="font-family:var(--font-serif);font-size:20px;color:var(--text-main);margin-bottom:12px;font-weight:400;">Planned Seminar Themes</h3>
          <div style="display:flex;flex-direction:column;gap:0;border:1px solid var(--border-light);">
            {[
              "Open access and the future of scholarly publishing",
              "Journal evaluation: beyond the impact factor",
              "Peer review reform: evidence and alternatives",
              "AI and academic publishing: governance challenges",
              "Youth digital environments: research and policy",
              "Five-Year Plan and higher education: policy implications",
            ].map((theme) => (
              <div style="padding:14px 20px;border-bottom:1px solid var(--border-light);font-size:15px;color:var(--text-secondary);">{theme}</div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 900px) {
  div[style*="grid-template-columns:1fr 2fr"] { display: block !important; }
}
</style>
