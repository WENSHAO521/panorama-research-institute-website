---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const orgUnits = [
  { unit: "Institute Office",             role: "Administration, governance, communications" },
  { unit: "Research Centers",             role: "Academic research and project management" },
  { unit: "Publications Unit",            role: "Research reports, working papers, briefs" },
  { unit: "Academic Events Unit",         role: "Conferences, seminars, workshops" },
  { unit: "Scholar & Fellowship Program", role: "Fellows, visiting scholars, research assistants" },
  { unit: "Collaboration Office",         role: "Partnerships, proposals, institutional MoUs" },
];
---
<BaseLayout title="Organizational Structure" description="The organizational structure of Panorama Research Institute.">
  <PageHero
    title="Organizational Structure"
    description="The internal organizational structure of Panorama Research Institute, including its administrative units, research centers, and academic programs."
    breadcrumbs={[{ label: "Institute", href: "/about" }, { label: "Framework", href: "/framework" }, { label: "Organizational Structure" }]}
  />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div class="section-label">Governance Hierarchy</div>
      <h2 class="section-title">Position within Panorama Scholarly Group</h2>
      <div class="org-structure-card">
        <div class="org-hierarchy">
          <div class="org-node org-node-parent">
            Panorama Scholarly Group
          </div>
          <div class="org-connector"></div>
          <div class="org-node org-node-institute">
            Panorama Research Institute
          </div>
          <div class="org-branch"></div>
          <div class="org-unit-grid">
            {orgUnits.map((u, index) => (
              <div class="org-unit-card">
                <div class="org-unit-index">{String(index + 1).padStart(2, '0')}</div>
                <div>
                  <div class="org-unit-title">{u.unit}</div>
                  <div class="org-unit-role">{u.role}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
    <div class="container">
      <div class="section-label">Administrative Units</div>
      <h2 class="section-title">Units and Functions</h2>
      <div style="margin-top:8px;">
        {[
          {
            unit: "Institute Office",
            head: "Director, Panorama Research Institute",
            desc: "The Institute Office is responsible for overall administration, governance compliance, communications, human resources, and coordination between units. It maintains the Institute's official records, manages institutional correspondence, and serves as the primary point of contact for external inquiries.",
            functions: ["Governance administration and compliance", "Official communications and media", "Scholar and staff coordination", "Budget coordination with Panorama Scholarly Group", "Website and digital presence management"],
          },
          {
            unit: "Research Centers",
            head: "Director of Research / Center Directors",
            desc: "The Research Centers are the primary academic units of the Institute. Each center has a defined thematic mandate, a dedicated director, and a team of affiliated researchers. Centers develop and manage research projects, produce publications, organize events, and build partnerships relevant to their domain.",
            functions: ["Development and management of research projects", "Center-specific publication programs", "Center-organized academic events and seminars", "Engagement of visiting scholars and project contributors", "Partnership development within the center's domain"],
          },
          {
            unit: "Publications Unit",
            head: "Publications Coordinator",
            desc: "The Publications Unit manages the editorial, production, and dissemination processes for all Institute publications, including research reports, working papers, policy briefs, edited volumes, and the annual report.",
            functions: ["Editorial review and quality control", "Publication formatting and production", "Open access dissemination", "Citation and metadata management", "Publication ethics compliance"],
          },
          {
            unit: "Academic Events Unit",
            head: "Events Coordinator",
            desc: "The Academic Events Unit plans and manages the Institute's program of conferences, seminars, workshops, and training programs. It coordinates calls for papers and chapters, manages registration and logistics, and produces event proceedings where applicable.",
            functions: ["Conference and seminar planning and coordination", "Workshop and training program delivery", "Call for papers / chapters administration", "Event proceedings and documentation", "Speaker and participant management"],
          },
          {
            unit: "Scholar & Fellowship Program",
            head: "Scholar Program Coordinator",
            desc: "The Scholar and Fellowship Program manages the recruitment, onboarding, and support of research fellows, associate research fellows, visiting scholars, and research assistants. It maintains scholar profiles and coordinates with research centers on scholar assignments.",
            functions: ["Fellowship application review and onboarding", "Visiting scholar coordination", "Research assistant supervision", "Scholar profile maintenance", "Advisory board engagement"],
          },
          {
            unit: "Collaboration Office",
            head: "Collaboration Coordinator",
            desc: "The Collaboration Office manages the Institute's external partnership activities, including institutional cooperation agreements, research project proposals from external parties, edited volume and special issue proposals, and event co-organization requests.",
            functions: ["Institutional cooperation agreements", "External research proposal review", "Partnership and MoU administration", "Event co-organization management", "Collaboration inquiry responses"],
          },
        ].map((unit) => (
          <div style="padding:36px 0;border-bottom:1px solid var(--border-light);">
            <div style="display:grid;grid-template-columns:220px 1fr;gap:40px;align-items:start;">
              <div>
                <h2 style="font-family:var(--font-serif);font-size:20px;color:var(--text-main);margin-bottom:8px;font-weight:400;">{unit.unit}</h2>
                <div style="font-size:12.5px;color:var(--text-muted);font-family:var(--font-sans);line-height:1.5;">{unit.head}</div>
              </div>
              <div>
                <p style="font-size:15px;line-height:1.8;color:var(--text-secondary);margin-bottom:16px;">{unit.desc}</p>
                <div style="display:flex;flex-direction:column;gap:4px;">
                  {unit.functions.map((fn) => (
                    <div style="display:flex;gap:10px;font-size:13.5px;color:var(--text-secondary);">
                      <span style="color:var(--text-muted);flex-shrink:0;">&#8212;</span>{fn}
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--bg-white);border-top:1px solid var(--border-light);">
    <div class="container">
      <div class="section-label">Research Centers</div>
      <h2 class="section-title">Active and Planned Centers</h2>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--border-light);border:1px solid var(--border-light);margin-top:8px;">
        {[
          { num: "01", name: "Center for Scholarly Publishing Studies",        status: "Active",   href: "/research-centers/scholarly-publishing-studies" },
          { num: "02", name: "Center for Scholarly Indexing and Evaluation",   status: "Active",   href: "/research-centers/scholarly-indexing-evaluation" },
          { num: "03", name: "Center for Policy and Social Research",          status: "Active",   href: "/research-centers/policy-social-research" },
          { num: "04", name: "Center for AI and Future Society",               status: "Upcoming", href: "/research-centers/ai-future-society" },
          { num: "05", name: "Center for Education and Learning Research",     status: "Planned",  href: "/research-centers" },
          { num: "06", name: "Center for Arts, Culture and Embodiment",        status: "Planned",  href: "/research-centers" },
        ].map((c) => (
          <a href={c.href} class="card" style="border:none;border-radius:0;display:block;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;">
              <span style="font-family:var(--font-mono);font-size:12px;color:var(--text-muted);">{c.num}</span>
              <span class={`tag ${c.status === 'Active' ? 'tag-active' : c.status === 'Upcoming' ? 'tag-steel' : ''}`}>{c.status}</span>
            </div>
            <div style="font-family:var(--font-serif);font-size:17px;color:var(--text-main);line-height:1.3;">{c.name}</div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 900px) {
  div[style*="grid-template-columns:220px 1fr"] { display: block !important; }
  div[style*="grid-template-columns:repeat(2,1fr)"] { display: block !important; }
}
</style>
