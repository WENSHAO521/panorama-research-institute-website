---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, platforms, researchAreas, researchCenters, featuredProjects, featuredPublications, upcomingEvents } from '../data/site';

const homeFrameworkUnits = [
  { unit: "Research Centers",              role: "Specialized academic units" },
  { unit: "Research Projects",             role: "Institute-supported initiatives" },
  { unit: "Publications Unit",             role: "Reports, papers, briefs" },
  { unit: "Academic Events",               role: "Conferences, seminars, workshops" },
  { unit: "Scholar & Fellowship Program",  role: "Fellows, visitors, research assistants" },
  { unit: "Collaboration Office",          role: "Partnerships, proposals, MoUs" },
];
---

<BaseLayout
  title="Panorama Research Institute"
  description={site.description}
>

<!-- ── 02 Hero ── -->
<section class="hero-section" style="background:var(--bg-main);border-bottom:1px solid var(--border-light);">
  <div class="container">
    <div class="hero-inner">
      <!-- Left: text -->
      <div class="hero-text">
        <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.14em;text-transform:uppercase;color:var(--text-muted);margin-bottom:28px;">
          An Academic Platform within Panorama Scholarly Group
        </div>
        <h1 style="font-family:var(--font-serif);font-size:clamp(38px,5.5vw,60px);line-height:1.08;letter-spacing:-0.035em;color:var(--text-main);margin-bottom:28px;max-width:600px;">
          Panorama Research Institute
        </h1>
        <p style="font-size:18px;line-height:1.75;color:var(--text-secondary);max-width:560px;margin-bottom:36px;">
          Research, scholarly infrastructure, and academic collaboration. The Institute supports interdisciplinary research, scholarly publishing studies, journal indexing and evaluation, policy analysis, and the development of global scholarly communication infrastructure.
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:12px;">
          <a href="/about"            class="btn btn-primary">Explore the Institute</a>
          <a href="/research-centers" class="btn btn-secondary">View Research Centers</a>
          <a href="/charter"          class="btn btn-ghost">Read the Charter &rarr;</a>
        </div>
      </div>

      <!-- Right: abstract research structure graphic -->
      <div class="hero-graphic" aria-hidden="true">
        <svg viewBox="0 0 480 400" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;max-width:480px;">
          <!-- Grid background -->
          <defs>
            <pattern id="grid" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
              <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#DADDDD" stroke-width="0.5"/>
            </pattern>
          </defs>
          <rect width="480" height="400" fill="url(#grid)" />

          <!-- Central node: PRI -->
          <rect x="170" y="160" width="140" height="80" rx="2" fill="white" stroke="#1F2326" stroke-width="1.5"/>
          <text x="240" y="195" text-anchor="middle" font-family="'IBM Plex Sans',sans-serif" font-size="11" font-weight="600" fill="#1F2326" letter-spacing="1">PANORAMA</text>
          <text x="240" y="212" text-anchor="middle" font-family="'IBM Plex Sans',sans-serif" font-size="10" fill="#5C6368" letter-spacing="0.5">RESEARCH INSTITUTE</text>

          <!-- Top node: Research Centers -->
          <rect x="166" y="40" width="148" height="56" rx="2" fill="white" stroke="#DADDDD" stroke-width="1"/>
          <text x="240" y="65" text-anchor="middle" font-family="'IBM Plex Sans',sans-serif" font-size="10" font-weight="600" fill="#1F2326">Research Centers</text>
          <text x="240" y="82" text-anchor="middle" font-family="'IBM Plex Sans',sans-serif" font-size="9" fill="#8A9196">4 active centers</text>
          <line x1="240" y1="96" x2="240" y2="160" stroke="#DADDDD" stroke-width="1" stroke-dasharray="4 3"/>

          <!-- Bottom node: Publications -->
          <rect x="166" y="304" width="148" height="56" rx="2" fill="white" stroke="#DADDDD" stroke-width="1"/>
          <text x="240" y="329" text-anchor="middle" font-family="'IBM Plex Sans',sans-serif" font-size="10" font-weight="600" fill="#1F2326">Publications</text>
          <text x="240" y="346" text-anchor="middle" font-family="'IBM Plex Sans',sans-serif" font-size="9" fill="#8A9196">Reports &middot; Papers &middot; Briefs</text>
          <line x1="240" y1="240" x2="240" y2="304" stroke="#DADDDD" stroke-width="1" stroke-dasharray="4 3"/>

          <!-- Left node: Projects -->
          <rect x="20" y="164" width="120" height="56" rx="2" fill="white" stroke="#DADDDD" stroke-width="1"/>
          <text x="80" y="189" text-anchor="middle" font-family="'IBM Plex Sans',sans-serif" font-size="10" font-weight="600" fill="#1F2326">Projects</text>
          <text x="80" y="206" text-anchor="middle" font-family="'IBM Plex Sans',sans-serif" font-size="9" fill="#8A9196">5 active initiatives</text>
          <line x1="140" y1="192" x2="170" y2="200" stroke="#DADDDD" stroke-width="1" stroke-dasharray="4 3"/>

          <!-- Right node: Scholars -->
          <rect x="340" y="164" width="120" height="56" rx="2" fill="white" stroke="#DADDDD" stroke-width="1"/>
          <text x="400" y="189" text-anchor="middle" font-family="'IBM Plex Sans',sans-serif" font-size="10" font-weight="600" fill="#1F2326">Scholars</text>
          <text x="400" y="206" text-anchor="middle" font-family="'IBM Plex Sans',sans-serif" font-size="9" fill="#8A9196">Fellows &middot; Visitors</text>
          <line x1="310" y1="192" x2="340" y2="200" stroke="#DADDDD" stroke-width="1" stroke-dasharray="4 3"/>

          <!-- Top-left: Scholarly Indexing -->
          <rect x="20" y="40" width="128" height="52" rx="2" fill="#F7F7F5" stroke="#C5C9C9" stroke-width="1"/>
          <text x="84" y="63" text-anchor="middle" font-family="'IBM Plex Sans',sans-serif" font-size="9.5" font-weight="600" fill="#375A6B">Scholarly Indexing</text>
          <text x="84" y="79" text-anchor="middle" font-family="'IBM Plex Sans',sans-serif" font-size="8.5" fill="#8A9196">POSI Project</text>
          <line x1="148" y1="66" x2="170" y2="175" stroke="#E6E8E8" stroke-width="1"/>

          <!-- Top-right: Policy Research -->
          <rect x="332" y="40" width="128" height="52" rx="2" fill="#F7F7F5" stroke="#C5C9C9" stroke-width="1"/>
          <text x="396" y="63" text-anchor="middle" font-family="'IBM Plex Sans',sans-serif" font-size="9.5" font-weight="600" fill="#375A6B">Policy Research</text>
          <text x="396" y="79" text-anchor="middle" font-family="'IBM Plex Sans',sans-serif" font-size="8.5" fill="#8A9196">Social &middot; Governance</text>
          <line x1="332" y1="66" x2="310" y2="175" stroke="#E6E8E8" stroke-width="1"/>

          <!-- Bottom-left: Academic Events -->
          <rect x="20" y="308" width="128" height="52" rx="2" fill="#F7F7F5" stroke="#C5C9C9" stroke-width="1"/>
          <text x="84" y="331" text-anchor="middle" font-family="'IBM Plex Sans',sans-serif" font-size="9.5" font-weight="600" fill="#375A6B">Academic Events</text>
          <text x="84" y="347" text-anchor="middle" font-family="'IBM Plex Sans',sans-serif" font-size="8.5" fill="#8A9196">Conf. &middot; Seminars</text>
          <line x1="148" y1="334" x2="170" y2="240" stroke="#E6E8E8" stroke-width="1"/>

          <!-- Bottom-right: Collaboration -->
          <rect x="332" y="308" width="128" height="52" rx="2" fill="#F7F7F5" stroke="#C5C9C9" stroke-width="1"/>
          <text x="396" y="331" text-anchor="middle" font-family="'IBM Plex Sans',sans-serif" font-size="9.5" font-weight="600" fill="#375A6B">Collaboration</text>
          <text x="396" y="347" text-anchor="middle" font-family="'IBM Plex Sans',sans-serif" font-size="8.5" fill="#8A9196">Institutional &middot; Partners</text>
          <line x1="332" y1="334" x2="310" y2="240" stroke="#E6E8E8" stroke-width="1"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<!-- ── 03 Institutional Statement ── -->
<section class="section-compact" style="background:var(--bg-white);">
  <div class="container">
    <div style="max-width:880px;">
      <div class="statement-box">
        <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-muted);margin-bottom:14px;">
          Institutional Status
        </div>
        <h2 style="font-family:var(--font-serif);font-size:22px;color:var(--text-main);margin-bottom:14px;font-weight:400;">
          An Academic Platform within Panorama Scholarly Group
        </h2>
        <p style="font-size:15.5px;line-height:1.7;color:var(--text-secondary);margin-bottom:10px;">
          Panorama Research Institute operates as an independent academic platform under the governance of Panorama Scholarly Group. It is an internal research and academic development division and is not a separate legal entity.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ── 04 Institute Framework Preview ── -->
<section class="section" style="background:var(--bg-main);">
  <div class="container">
    <div style="margin-bottom:56px;">
      <h2 class="section-title">Institute Framework</h2>
      <p class="section-desc">
        A structured research and academic development platform supporting projects, publications, centers, events, scholars, and institutional collaboration.
      </p>
    </div>

    <div class="org-structure-card" style="margin-bottom:48px;">
      <div class="org-hierarchy">
        <div class="org-node org-node-parent">
          Panorama Scholarly Group
        </div>
        <div class="org-connector"></div>
        <div class="org-node org-node-institute">
          Panorama Research Institute
        </div>
        <div class="org-branch"></div>
        <div class="org-unit-grid">
          {homeFrameworkUnits.map((item, index) => (
            <div class="org-unit-card">
              <div class="org-unit-index">{String(index + 1).padStart(2, '0')}</div>
              <div>
                <div class="org-unit-title">{item.unit}</div>
                <div class="org-unit-role">{item.role}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <a href="/framework" class="btn btn-secondary">View Full Framework</a>
  </div>
</section>

<!-- ── 05 Research Areas ── -->
<section class="section" style="background:var(--bg-white);border-top:1px solid var(--border-light);">
  <div class="container">
    <div style="margin-bottom:56px;">
      <h2 class="section-title">Research Areas</h2>
      <p class="section-desc">
        The Institute focuses on research fields that connect scholarly communication, journal evaluation, public policy, education, technology, and cultural studies.
      </p>
    </div>
    <div class="areas-grid">
      {researchAreas.map((area) => (
        <div class="area-card">
          <div class="area-num">{area.num}</div>
          <h3 class="area-title">{area.title}</h3>
          <p class="area-text">{area.desc}</p>
        </div>
      ))}
    </div>
    <div style="margin-top:40px;">
      <a href="/research-areas" class="btn btn-secondary">View All Research Areas</a>
    </div>
  </div>
</section>

<!-- ── 06 Research Centers ── -->
<section class="section" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
  <div class="container">
    <div style="margin-bottom:48px;">
      <h2 class="section-title">Research Centers</h2>
      <p class="section-desc">
        The Institute organizes its academic activities through specialized research centers that support projects, publications, events, and partnerships.
      </p>
    </div>
    <div>
      {researchCenters.map((center) => (
        <div class="center-card">
          <div class="center-num">{center.num}</div>
          <div>
            <h3 style="font-family:var(--font-serif);font-size:20px;color:var(--text-main);margin-bottom:6px;">{center.name}</h3>
            <div style="display:flex;flex-wrap:wrap;gap:6px;">
              {center.areas.map((a) => <span class="tag">{a}</span>)}
              {center.upcoming && <span class="tag tag-steel">Upcoming</span>}
            </div>
          </div>
          <a href={center.href} class="btn btn-ghost" style="padding-top:0;">View Center &rarr;</a>
        </div>
      ))}
    </div>
    <div style="margin-top:40px;">
      <a href="/research-centers" class="btn btn-secondary">All Research Centers</a>
    </div>
  </div>
</section>

<!-- ── 07 Featured Projects ── -->
<section class="section" style="background:var(--bg-white);border-top:1px solid var(--border-light);">
  <div class="container">
    <div style="margin-bottom:56px;">
      <h2 class="section-title">Featured Projects</h2>
      <p class="section-desc">
        Current research initiatives developed or supported by Panorama Research Institute.
      </p>
    </div>
    <div class="projects-grid">
      {featuredProjects.map((p) => (
        <div class="project-card">
          <div style="margin-bottom:16px;">
            <span class={`tag ${p.status === 'Active' ? 'tag-active' : p.status === 'Call for Participation' ? 'tag-steel' : ''}`}>
              {p.status}
            </span>
          </div>
          <h3 class="project-title">{p.title}</h3>
          <p class="project-desc">{p.desc}</p>
          <a href={p.href} style="display:inline-flex;align-items:center;gap:6px;margin-top:20px;font-size:13.5px;font-weight:500;color:var(--accent-steel);font-family:var(--font-sans);">
            View Project &rarr;
          </a>
        </div>
      ))}
    </div>
    <div style="margin-top:40px;">
      <a href="/projects" class="btn btn-secondary">All Research Projects</a>
    </div>
  </div>
</section>

<!-- ── 08 Publications ── -->
<section class="section" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
  <div class="container">
    <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:48px;gap:24px;">
      <div>
        <h2 class="section-title" style="margin-bottom:12px;">Publications</h2>
        <p class="section-desc">
          Research reports, working papers, policy briefs, edited volumes, and annual reports produced or supported by the Institute.
        </p>
      </div>
      <a href="/publications" class="btn btn-secondary" style="flex-shrink:0;">All Publications</a>
    </div>

    <div>
      {featuredPublications.map((pub) => (
        <div class="publication-item">
          <div class="pub-type">{pub.type}</div>
          <div>
            <div class="pub-title">{pub.title}</div>
            <div class="pub-meta">{pub.team}</div>
          </div>
          <div style="text-align:right;">
            <div style="font-family:var(--font-mono);font-size:13px;color:var(--text-muted);margin-bottom:12px;">{pub.year}</div>
            <a href="/publications" class="btn btn-ghost" style="font-size:13px;">Details &rarr;</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── 09 Charter & Governance Preview ── -->
<section class="section" style="background:var(--bg-white);border-top:1px solid var(--border-light);">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:start;">
      <div>
        <h2 class="section-title">Charter &amp; Governance</h2>
        <p class="section-desc" style="margin-bottom:32px;">
          The Institute operates through a structured internal charter, governance rules, research ethics principles, publication policies, and collaboration procedures.
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:10px;">
          <a href="/charter"                              class="btn btn-primary">Read the Charter</a>
          <a href="/governance/research-ethics"           class="btn btn-secondary">View Governance Policies</a>
        </div>
      </div>
      <div>
        {[
          { label: "Institute Charter",              href: "/charter" },
          { label: "Governance Rules",               href: "/governance/rules" },
          { label: "Research Ethics",                href: "/governance/research-ethics" },
          { label: "Academic Independence Statement",href: "/governance/academic-independence" },
          { label: "Conflict of Interest Policy",    href: "/governance/conflict-of-interest" },
          { label: "Publication & Report Policy",    href: "/governance/publication-report-policy" },
          { label: "Data & Documentation Policy",    href: "/governance/data-documentation-policy" },
        ].map((item) => (
          <a href={item.href} style="display:flex;justify-content:space-between;align-items:center;padding:14px 0;border-bottom:1px solid var(--border-light);font-size:14.5px;color:var(--text-main);transition:color 0.15s;font-family:var(--font-sans);">
            {item.label}
            <span style="color:var(--text-muted);font-size:13px;">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ── 10 Events & Calls ── -->
<section class="section" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
  <div class="container">
    <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:48px;gap:24px;">
      <div>
        <h2 class="section-title" style="margin-bottom:12px;">Events &amp; Calls</h2>
        <p class="section-desc">Upcoming conferences, seminars, workshops, and calls for papers and chapters.</p>
      </div>
      <a href="/events" class="btn btn-secondary" style="flex-shrink:0;">All Events</a>
    </div>
    <div>
      {upcomingEvents.map((ev) => (
        <div class="event-item">
          <div class="event-date">{ev.date.split(' ')[0]}<br />{ev.date.split(' ')[1]}</div>
          <div>
            <span class="tag" style="margin-bottom:10px;display:inline-flex;">{ev.type}</span>
            <h3 class="event-title">{ev.title}</h3>
            <p class="event-meta">{ev.location}</p>
          </div>
          <div style="text-align:right;padding-top:4px;">
            <span class="tag tag-steel">{ev.status}</span>
          </div>
        </div>
      ))}
    </div>
    <div style="margin-top:32px;display:flex;gap:12px;flex-wrap:wrap;">
      <a href="/events/calls-for-papers"   class="btn btn-secondary">Calls for Papers</a>
      <a href="/events/calls-for-chapters" class="btn btn-secondary">Calls for Chapters</a>
    </div>
  </div>
</section>

<!-- ── 11 Collaboration ── -->
<section class="section" style="background:var(--bg-dark);border-top:1px solid var(--border-light);">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center;">
      <div>
        <h2 style="font-family:var(--font-serif);font-size:clamp(26px,3.5vw,38px);line-height:1.2;color:var(--text-inverse);margin-bottom:20px;letter-spacing:-0.02em;">
          Collaborate with Panorama Research Institute
        </h2>
        <p style="font-size:16px;line-height:1.75;color:rgba(255,255,255,0.6);margin-bottom:32px;">
          The Institute welcomes academic collaboration, institutional partnerships, research project proposals, edited volume proposals, visiting scholar applications, and academic event cooperation.
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:10px;">
          <a href="/collaboration/submit" style="background:var(--bg-white);color:var(--text-main);border:1px solid var(--bg-white);" class="btn">Submit a Proposal</a>
          <a href="/contact"             style="background:transparent;color:var(--text-inverse);border:1px solid rgba(255,255,255,0.3);" class="btn">Contact the Institute</a>
        </div>
      </div>
      <div>
        {[
          "Institutional Cooperation",
          "Research Project Proposal",
          "Edited Volume Proposal",
          "Special Issue Proposal",
          "Visiting Scholar Application",
          "Research Fellow Application",
          "Academic Event Cooperation",
        ].map((type) => (
          <div style="display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.08);">
            <span style="width:5px;height:5px;background:rgba(255,255,255,0.3);border-radius:50%;flex-shrink:0;"></span>
            <span style="font-size:14.5px;color:rgba(255,255,255,0.7);font-family:var(--font-sans);">{type}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ── 12 Panorama Scholarly Ecosystem ── -->
<section class="section-compact" style="background:var(--bg-white);border-top:1px solid var(--border-light);">
  <div class="container">
    <div style="margin-bottom:40px;">
      <h2 class="section-title">Part of the Panorama Scholarly Ecosystem</h2>
    </div>
    <div class="platform-grid platform-grid-refined">
      {platforms.map((p) => (
        <a href={p.href} target="_blank" rel="noopener noreferrer" class="platform-card">
          <div class={`platform-logo-box ${p.logoTheme === 'dark' ? 'platform-logo-box-dark' : ''}`}>
            <img src={p.logo} alt={`${p.name} logo`} loading="lazy" class="platform-logo" />
            <span class="platform-logo-fallback">{p.name}</span>
          </div>
          <div class="platform-card-body">
            <div>
              <div class="platform-card-name">{p.name}</div>
              <div class="platform-card-desc">{p.desc}</div>
            </div>
            <div class="platform-card-action">Visit <span aria-hidden="true">&rarr;</span></div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

</BaseLayout>

<style>
.hero-section {
  padding: 100px 0 96px;
}
.hero-inner {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 72px;
  align-items: center;
}
.hero-graphic {
  display: flex;
  justify-content: center;
  align-items: center;
}
.areas-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border-light);
  border: 1px solid var(--border-light);
}
.areas-grid .area-card {
  border: none;
  border-radius: 0;
}
.areas-grid .area-card:hover {
  transform: none;
  background: var(--bg-soft);
}
.projects-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1px;
  background: var(--border-light);
  border: 1px solid var(--border-light);
}
.projects-grid .project-card {
  border: none;
  border-radius: 0;
}
.projects-grid .project-card:hover {
  transform: none;
  background: var(--bg-soft);
}
.platform-logo-box {
  min-height: 116px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 22px 20px;
  margin-bottom: 22px;
  border: 1px solid rgba(31, 35, 38, 0.10);
  border-radius: 8px;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.96), rgba(247,247,245,0.92));
}
.platform-logo-box-dark {
  background:
    radial-gradient(circle at 20% 0%, rgba(255,255,255,0.10), transparent 32%),
    linear-gradient(135deg, #252A2E, #15191C);
  border-color: rgba(31, 35, 38, 0.28);
}
.platform-logo {
  width: auto;
  max-width: 92%;
  max-height: 44px;
  object-fit: contain;
}
.platform-logo-fallback {
  max-width: 100%;
  color: var(--text-secondary);
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.08em;
  line-height: 1.25;
