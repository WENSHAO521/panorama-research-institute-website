---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="Join the Institute" description="How to join Panorama Research Institute as a Research Fellow, Associate Fellow, Visiting Scholar, or Research Assistant.">
  <PageHero
    title="Join the Institute"
    description="Panorama Research Institute welcomes applications from scholars and researchers who wish to contribute to the Institute's research program through fellowship, visiting scholar, or research assistant roles."
    breadcrumbs={[{ label: "People", href: "/people" }, { label: "Join the Institute" }]}
  />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);max-width:720px;margin-bottom:48px;">
        The Institute is actively building its scholarly community in its foundational phase. We welcome applications from researchers across all career stages who are working in the Institute's research areas and wish to contribute to a rigorous, collaborative, and independent research environment.
      </p>

      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--border-light);border:1px solid var(--border-light);">
        {[
          {
            role:   "Research Fellow",
            target: "Mid- and senior-career researchers with a PhD or equivalent",
            commit: "Minimum 1 publication per year; participate in Institute events",
            format: "Remote (distributed) — no relocation required",
            duration:"1–3 years, renewable",
            href:   "/collaboration/research-fellow-application",
            cta:    "Apply as Research Fellow",
          },
          {
            role:   "Associate Research Fellow",
            target: "Doctoral students and early-career researchers",
            commit: "Active contribution to Institute projects",
            format: "Remote (distributed)",
            duration:"1 year, renewable",
            href:   "/collaboration/research-fellow-application",
            cta:    "Apply as Associate Fellow",
          },
          {
            role:   "Visiting Scholar",
            target: "Established researchers (PhD or equivalent) from other institutions",
            commit: "Active research contribution during affiliation period",
            format: "Remote or in-person (3–12 months)",
            duration:"3–12 months",
            href:   "/collaboration/visiting-scholar-application",
            cta:    "Apply as Visiting Scholar",
          },
          {
            role:   "Research Assistant",
            target: "Masters/PhD students or recent graduates with research experience",
            commit: "Project-specific tasks under Fellow supervision",
            format: "Remote (distributed)",
            duration:"Project-based",
            href:   "/people/research-assistants",
            cta:    "View Openings",
          },
        ].map((item) => (
          <div class="card" style="border:none;border-radius:0;display:flex;flex-direction:column;justify-content:space-between;">
            <div>
              <h2 style="font-family:var(--font-serif);font-size:22px;color:var(--text-main);margin-bottom:20px;font-weight:400;">{item.role}</h2>
              <div style="display:flex;flex-direction:column;gap:14px;margin-bottom:24px;">
                {[
                  { label:"Suitable for", value:item.target },
                  { label:"Commitment",   value:item.commit },
                  { label:"Format",       value:item.format },
                  { label:"Duration",     value:item.duration },
                ].map((d) => (
                  <div>
                    <div style="font-size:11px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:3px;">{d.label}</div>
                    <div style="font-size:14px;color:var(--text-secondary);">{d.value}</div>
                  </div>
                ))}
              </div>
            </div>
            <a href={item.href} class="btn btn-primary" style="margin-top:auto;">{item.cta}</a>
          </div>
        ))}
      </div>

      <div style="margin-top:48px;max-width:720px;">
        <h2 style="font-family:var(--font-serif);font-size:22px;color:var(--text-main);margin-bottom:14px;font-weight:400;">What the Institute Offers</h2>
        <div style="display:flex;flex-direction:column;gap:4px;">
          {[
            "Formal institutional affiliation with Panorama Research Institute",
            "Publication support in the Institute's working paper, report, and policy brief series",
            "Access to the Institute's scholarly community, network, and resources",
            "Participation in Institute-organized seminars, workshops, and conferences",
            "Co-authorship and collaborative research opportunities",
            "A research environment committed to academic independence and integrity",
          ].map((item) => (
            <div style="display:flex;gap:10px;font-size:15px;color:var(--text-secondary);padding:8px 0;border-bottom:1px solid var(--bg-main);">
              <span style="color:var(--text-muted);flex-shrink:0;">&#8212;</span>{item}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 768px) {
  div[style*="grid-template-columns:repeat(2,1fr)"] { display: block !important; }
}
</style>
