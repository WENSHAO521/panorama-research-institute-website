---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="Project Contributors" description="Scholars who have contributed to specific Panorama Research Institute projects.">
  <PageHero
    title="Project Contributors"
    description="Scholars and practitioners who have contributed to specific Panorama Research Institute research projects, publications, or events without holding a formal Institute affiliation."
    breadcrumbs={[{ label: "People", href: "/people" }, { label: "Project Contributors" }]}
  />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div style="max-width:820px;">
        <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:40px;">
          Project contributors are scholars, practitioners, and experts who contribute to specific Panorama Research Institute research projects, publications, or events. They contribute their expertise on a project-specific basis without holding a formal fellowship or visiting affiliation with the Institute. Their contributions are acknowledged in the relevant project and publication records.
        </p>

        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border-light);border:1px solid var(--border-light);margin-bottom:40px;">
          {[
            { type:"Research Contributors",    desc:"Scholars who contribute data, analysis, or intellectual input to a specific research project, typically as co-authors or acknowledged contributors." },
            { type:"Chapter Authors",          desc:"Authors contributing chapters to an edited volume organized or co-published by the Institute, without a broader affiliation with the Institute." },
            { type:"Event Participants",       desc:"Speakers, panelists, and workshop participants who contribute to Institute events. Biographical information may be listed in event records." },
          ].map((item) => (
            <div class="card" style="border:none;border-radius:0;">
              <h3 style="font-family:var(--font-sans);font-size:15px;font-weight:600;color:var(--text-main);margin-bottom:10px;">{item.type}</h3>
              <p style="font-size:14px;line-height:1.7;color:var(--text-secondary);">{item.desc}</p>
            </div>
          ))}
        </div>

        <div style="padding:24px;background:var(--bg-soft);border:1px solid var(--border-light);margin-bottom:32px;">
          <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:var(--text-muted);margin-bottom:8px;">Current Contributors</div>
          <p style="font-size:14.5px;color:var(--text-secondary);margin:0;line-height:1.7;">
            The Institute is in its foundational phase. Contributors to specific projects will be listed here and in the relevant project and publication records as the Institute's research outputs are completed.
          </p>
        </div>

        <h2 style="font-family:var(--font-serif);font-size:22px;color:var(--text-main);margin-bottom:14px;font-weight:400;">Contribute to a Project</h2>
        <p style="font-size:15.5px;line-height:1.85;color:var(--text-secondary);margin-bottom:24px;">
          Researchers and practitioners interested in contributing to a specific Institute project should contact the lead Research Center for that project. Contributions may take the form of co-authorship, data contribution, peer review, event participation, or other forms depending on the project's needs.
        </p>
        <div style="display:flex;gap:10px;flex-wrap:wrap;">
          <a href="/projects/current" class="btn btn-primary">View Current Projects</a>
          <a href="/collaboration" class="btn btn-secondary">Collaboration</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 768px) {
  div[style*="grid-template-columns:repeat(3,1fr)"] { grid-template-columns: repeat(2,1fr) !important; }
}
@media (max-width: 500px) {
  div[style*="grid-template-columns:repeat(2,1fr)"] { display: block !important; }
}
</style>
