---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="Research Fellows" description="Research fellows affiliated with Panorama Research Institute.">
  <PageHero
    title="Research Fellows"
    description="Research Fellows are the core scholarly community of Panorama Research Institute, contributing original research, publications, and intellectual leadership to the Institute's programs."
    breadcrumbs={[{ label: "People", href: "/people" }, { label: "Research Fellows" }]}
  />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 2fr;gap:64px;align-items:start;">
        <div>
          <div class="section-label">Fellowship Details</div>
          <div style="display:flex;flex-direction:column;gap:16px;margin-top:8px;">
            {[
              { label:"Title",       value:"Research Fellow, Panorama Research Institute" },
              { label:"Duration",    value:"Typically 1–3 years, renewable" },
              { label:"Format",      value:"Remote / distributed (no relocation required)" },
              { label:"Output",      value:"At least one publication per year in Institute program" },
              { label:"Application", value:"Open (rolling)" },
              { label:"Contact",     value:"fellows@panorama-sg.com" },
            ].map((item) => (
              <div>
                <div style="font-size:11px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:4px;">{item.label}</div>
                <div style="font-size:14.5px;color:var(--text-main);">{item.value}</div>
              </div>
            ))}
          </div>
          <div style="margin-top:28px;">
            <a href="/collaboration/research-fellow-application" class="btn btn-primary" style="width:100%;justify-content:center;">Apply Now</a>
          </div>
        </div>
        <div>
          <h2 style="font-family:var(--font-serif);font-size:24px;color:var(--text-main);margin-bottom:16px;font-weight:400;">About Research Fellows</h2>
          <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:20px;">
            Research Fellows are the primary scholarly members of Panorama Research Institute. They are researchers who make a formal commitment to contribute to the Institute's research program through original research, publications, and participation in Institute events and activities.
          </p>
          <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:20px;">
            Research Fellows are affiliated with one or more of the Institute's research centers and contribute to ongoing projects within that center's mandate. They may also propose and lead new research projects, subject to review by the Institute's research committee.
          </p>
          <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:32px;">
            The fellowship is a voluntary academic appointment. Fellows retain their existing institutional affiliations and are not required to relocate. The Institute aims to build a geographically diverse fellowship cohort spanning multiple countries and disciplinary backgrounds.
          </p>

          <div style="padding:24px;background:var(--bg-soft);border:1px solid var(--border-light);margin-bottom:32px;">
            <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:var(--text-muted);margin-bottom:8px;">Current Cohort</div>
            <p style="font-size:14.5px;color:var(--text-secondary);margin:0;line-height:1.7;">
              The Institute is currently in its foundational phase and is building its inaugural cohort of Research Fellows. Applications are open. Accepted fellows will be listed on this page upon appointment.
            </p>
          </div>

          <h3 style="font-family:var(--font-sans);font-size:16px;font-weight:600;color:var(--text-main);margin-bottom:12px;">Fellowship Responsibilities</h3>
          <div style="display:flex;flex-direction:column;gap:4px;">
            {[
              "Contribute at least one publication to the Institute's working paper or other series per fellowship year",
              "Participate in at least one Institute seminar, workshop, or conference event per year",
              "Maintain active engagement with the Institute's research program and community",
              "Adhere to the Institute's research ethics and governance policies",
              "Disclose any conflicts of interest relevant to the Institute's research areas",
            ].map((item) => (
              <div style="display:flex;gap:10px;font-size:14px;color:var(--text-secondary);padding:6px 0;border-bottom:1px solid var(--bg-main);">
                <span style="color:var(--text-muted);flex-shrink:0;">&#8212;</span>{item}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 900px) {
  div[style*="grid-template-columns:1fr 2fr"] { display: block !important; }
}
</style>
