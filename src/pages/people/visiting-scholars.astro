---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="Visiting Scholars" description="Visiting scholars affiliated with Panorama Research Institute.">
  <PageHero
    title="Visiting Scholars"
    description="The Visiting Scholar Program enables established researchers to affiliate with Panorama Research Institute for a defined period to pursue research in collaboration with the Institute's scholars and centers."
    breadcrumbs={[{ label: "People", href: "/people" }, { label: "Visiting Scholars" }]}
  />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 2fr;gap:64px;align-items:start;">
        <div>
          <div class="section-label">Program Details</div>
          <div style="display:flex;flex-direction:column;gap:16px;margin-top:8px;">
            {[
              { label:"Title",        value:"Visiting Scholar, Panorama Research Institute" },
              { label:"Duration",     value:"3–12 months" },
              { label:"Format",       value:"Remote or in-person" },
              { label:"Eligibility",  value:"Established scholars (PhD or equivalent)" },
              { label:"Application",  value:"Rolling (subject to capacity)" },
              { label:"Contact",      value:"scholars@panorama-sg.com" },
            ].map((item) => (
              <div>
                <div style="font-size:11px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:4px;">{item.label}</div>
                <div style="font-size:14.5px;color:var(--text-main);">{item.value}</div>
              </div>
            ))}
          </div>
          <div style="margin-top:28px;">
            <a href="/collaboration/visiting-scholar-application" class="btn btn-primary" style="width:100%;justify-content:center;">Apply to Visit</a>
          </div>
        </div>
        <div>
          <h2 style="font-family:var(--font-serif);font-size:24px;color:var(--text-main);margin-bottom:16px;font-weight:400;">About the Visiting Scholar Program</h2>
          <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:20px;">
            The Visiting Scholar Program enables established researchers from other institutions to affiliate with Panorama Research Institute for a defined period, typically between three and twelve months. During this period, visiting scholars are hosted by one of the Institute's research centers, contribute to the intellectual life of the Institute, and pursue research of mutual interest.
          </p>
          <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:20px;">
            Visiting scholars may be in-person at Institute facilities, remote, or a combination of both, depending on the needs of the research project and the scholar's home institution arrangements. The Institute provides institutional affiliation, library access, and support for research activities.
          </p>
          <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:32px;">
            The Institute particularly welcomes visiting scholars working on research closely aligned with current Institute projects, and those who can contribute expertise that complements the existing scholarly community.
          </p>

          <h3 style="font-family:var(--font-sans);font-size:16px;font-weight:600;color:var(--text-main);margin-bottom:12px;">What Visiting Scholars Receive</h3>
          <div style="display:flex;flex-direction:column;gap:4px;margin-bottom:32px;">
            {[
              "Institutional affiliation as a Visiting Scholar of Panorama Research Institute",
              "Access to Institute resources, networks, and scholarly community",
              "Participation in Institute events, seminars, and research activities",
              "Support for publication in the Institute's working paper and report series",
              "Mentoring and feedback from affiliated researchers",
            ].map((item) => (
              <div style="display:flex;gap:10px;font-size:14px;color:var(--text-secondary);padding:6px 0;border-bottom:1px solid var(--bg-main);">
                <span style="color:var(--text-muted);flex-shrink:0;">&#8212;</span>{item}
              </div>
            ))}
          </div>

          <div style="padding:24px;background:var(--bg-soft);border:1px solid var(--border-light);">
            <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:var(--text-muted);margin-bottom:8px;">Current Scholars</div>
            <p style="font-size:14.5px;color:var(--text-secondary);margin:0;line-height:1.7;">
              The Institute is currently accepting applications for visiting scholars. Accepted visiting scholars will be listed on this page during their affiliation period.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 900px) {
  div[style*="grid-template-columns:1fr 2fr"] { display: block !important; }
}
</style>
