---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="Scholarly Publishing Standards Project" description="Research project developing editorial standards, publication ethics guidance, and scholarly communication frameworks for academic journals and publishers.">
  <PageHero
    title="Scholarly Publishing Standards Project"
    description="A research and standards development initiative producing editorial standards, publication ethics guidance, peer review frameworks, and scholarly communication benchmarks for academic journals and publishers."
    breadcrumbs={[{ label: "Research", href: "/research-areas" }, { label: "Projects", href: "/projects" }, { label: "Scholarly Publishing Standards" }]}
    tag="Active Project"
  >
  </PageHero>

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 2fr;gap:64px;align-items:start;">
        <div>
          <div class="section-label">Project Details</div>
          <div style="display:flex;flex-direction:column;gap:20px;margin-top:8px;">
            {[
              { label: "Status",       value: "Active" },
              { label: "Start Date",   value: "2026" },
              { label: "Lead Center",  value: "Center for Scholarly Publishing Studies" },
              { label: "Project Type", value: "Research and Standards Development" },
              { label: "Output Types", value: "Standards, guidelines, working papers" },
              { label: "Contact",      value: "research@panorama-sg.com" },
            ].map((item) => (
              <div>
                <div style="font-size:11px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:4px;">{item.label}</div>
                <div style="font-size:14.5px;color:var(--text-main);">{item.value}</div>
              </div>
            ))}
          </div>
          <div style="margin-top:32px;display:flex;flex-direction:column;gap:8px;">
            <a href="/research-centers/scholarly-publishing-studies" class="btn btn-primary" style="justify-content:center;">Lead Center</a>
            <a href="/resources/guidelines" class="btn btn-secondary" style="justify-content:center;">Project Guidelines</a>
          </div>
        </div>
        <div>
          <h2 style="font-family:var(--font-serif);font-size:28px;color:var(--text-main);margin-bottom:20px;font-weight:400;">About the Project</h2>
          <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:20px;">
            The Scholarly Publishing Standards Project is a combined research and standards development initiative led by the Center for Scholarly Publishing Studies. Its core purpose is to produce practical, evidence-based standards and guidance documents that journal editors, publishers, and scholarly institutions can use to improve the quality, transparency, and ethical integrity of their publishing practices.
          </p>
          <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:20px;">
            The project takes a research-grounded approach to standards development: standards and guidance documents are developed on the basis of systematic reviews of existing practices, analysis of current guidelines from bodies such as COPE, ICMJE, and WAME, and empirical research into the needs and challenges of journal editors and publishers.
          </p>
          <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);">
            All project outputs are made available under open access terms. The project welcomes feedback and input from journal editors, publishers, and researchers worldwide, and may be adapted for specific disciplinary or regional contexts.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
    <div class="container">
      <div class="section-label">Standards Areas</div>
      <h2 class="section-title">Planned Standards Documents</h2>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border-light);border:1px solid var(--border-light);margin-top:8px;">
        {[
          { num:"01", title:"Editorial Standards", status:"In Development", desc:"Standards for editorial scope, editorial board composition, editorial decision processes, manuscript tracking, and editorial transparency." },
          { num:"02", title:"Peer Review Standards", status:"In Development", desc:"Standards for peer review model selection, reviewer selection, reviewer guidance, review timelines, and handling of conflicts of interest in review." },
          { num:"03", title:"Publication Ethics Standards", status:"Planned", desc:"Standards for authorship, plagiarism handling, data fabrication and falsification, retraction policies, and editorial misconduct procedures." },
          { num:"04", title:"Open Access Standards", status:"Planned", desc:"Standards for open access policy disclosure, APC transparency, licensing, rights retention, self-archiving rights, and preprint policies." },
          { num:"05", title:"Research Data Standards", status:"Planned", desc:"Standards for data availability statements, data sharing, supplementary material, and research data management in journal publishing." },
          { num:"06", title:"Metadata and Discoverability", status:"Planned", desc:"Standards for article-level metadata, DOI registration, ORCID integration, funder acknowledgment, and abstract and keyword quality." },
        ].map((item) => (
          <div class="card" style="border:none;border-radius:0;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;">
              <span style="font-family:var(--font-mono);font-size:11px;color:var(--text-muted);">{item.num}</span>
              <span class={`tag ${item.status === 'In Development' ? 'tag-active' : ''}`} style="font-size:10px;">{item.status}</span>
            </div>
            <h3 style="font-family:var(--font-sans);font-size:15px;font-weight:600;color:var(--text-main);margin-bottom:10px;">{item.title}</h3>
            <p style="font-size:14px;line-height:1.7;color:var(--text-secondary);">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--bg-white);border-top:1px solid var(--border-light);">
    <div class="container">
      <div class="section-label">Research Publications</div>
      <h2 class="section-title">Project Publications</h2>
      <div style="margin-top:8px;">
        {[
          { type:"Working Paper", title:"Peer Review Models and Publication Ethics in the Digital Age", year:"2026", status:"Available" },
          { type:"Standards Document", title:"Editorial Standards for Academic Journals: Draft v0.1", year:"2026", status:"In preparation" },
        ].map((pub) => (
          <div class="publication-item">
            <div class="pub-type">{pub.type}</div>
            <div class="pub-title">{pub.title}</div>
            <div style="text-align:right;">
              <div style="font-family:var(--font-mono);font-size:12px;color:var(--text-muted);margin-bottom:4px;">{pub.year}</div>
              <div style="font-family:var(--font-mono);font-size:12px;color:var(--accent-steel);">{pub.status}</div>
            </div>
          </div>
        ))}
      </div>
      <div style="margin-top:32px;">
        <a href="/publications" class="btn btn-secondary">All Publications</a>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 900px) {
  div[style*="grid-template-columns:1fr 2fr"] { display: block !important; }
  div[style*="grid-template-columns:repeat(3,1fr)"] { grid-template-columns: repeat(2,1fr) !important; }
}
@media (max-width: 600px) {
  div[style*="grid-template-columns:repeat(3,1fr)"],
  div[style*="grid-template-columns:repeat(2,1fr)"] { display: block !important; }
}
</style>
