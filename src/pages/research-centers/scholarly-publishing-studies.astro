---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="Center for Scholarly Publishing Studies" description="Research center focused on open access, peer review, publication ethics, and scholarly communication.">
  <PageHero
    title="Center for Scholarly Publishing Studies"
    description="Research on open access models, peer review processes, editorial standards, publication ethics, and the evolving landscape of scholarly communication."
    breadcrumbs={[{ label: "Research", href: "/research-areas" }, { label: "Research Centers", href: "/research-centers" }, { label: "Scholarly Publishing Studies" }]}
    tag="Active Research Center"
  >
    <div style="margin-top:4px;font-size:14px;color:var(--text-muted);font-family:var(--font-sans);">学术出版研究中心</div>
  </PageHero>

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 2fr;gap:64px;align-items:start;">
        <div>
          <div class="section-label">At a Glance</div>
          <div style="display:flex;flex-direction:column;gap:20px;margin-top:8px;">
            {[
              { label: "Center Status",      value: "Active" },
              { label: "Established",        value: "2024" },
              { label: "Research Area",      value: "Scholarly Publishing Studies" },
              { label: "Active Projects",    value: "2" },
              { label: "Publications",       value: "2 Working Papers, 1 Report" },
              { label: "Contact",            value: "research@panorama-sg.com" },
            ].map((item) => (
              <div>
                <div style="font-size:11px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:4px;">{item.label}</div>
                <div style="font-size:14.5px;color:var(--text-main);">{item.value}</div>
              </div>
            ))}
          </div>
          <div style="margin-top:32px;display:flex;flex-direction:column;gap:8px;">
            <a href="/collaboration/research-project-proposal"  class="btn btn-primary" style="justify-content:center;">Submit a Proposal</a>
            <a href="/collaboration/visiting-scholar-application" class="btn btn-secondary" style="justify-content:center;">Visiting Scholar</a>
          </div>
        </div>
        <div>
          <h2 style="font-family:var(--font-serif);font-size:28px;color:var(--text-main);margin-bottom:20px;font-weight:400;">About the Center</h2>
          <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:20px;">
            The Center for Scholarly Publishing Studies is Panorama Research Institute's primary research unit focusing on the structures, practices, and challenges of academic publishing. The Center conducts original research on the mechanisms by which scholarly knowledge is produced, evaluated, communicated, and preserved.
          </p>
          <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:20px;">
            Research at the Center engages critically with questions of openness, quality, accountability, and ethics in academic publishing. It examines how publishing models shape research incentives, how peer review systems function and fail, and how editorial standards can be developed and maintained across diverse disciplinary contexts.
          </p>
          <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);">
            The Center works closely with the Center for Scholarly Indexing and Evaluation on shared questions of journal quality and transparency, and with the Center for Policy and Social Research on policy dimensions of open science and research integrity.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
    <div class="container">
      <div class="section-label">Research Focus</div>
      <h2 class="section-title">Core Research Areas</h2>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border-light);border:1px solid var(--border-light);margin-top:8px;">
        {[
          { title: "Open Access",           desc: "Research on open access models, policies, mandates, APCs, diamond OA, rights retention, and the economics of open publishing." },
          { title: "Peer Review",           desc: "Research on peer review processes, reviewer quality, double-blind vs. open review, post-publication review, and reviewer training." },
          { title: "Publication Ethics",    desc: "Research on authorship, plagiarism, fabrication, falsification, retraction, predatory publishing, and editorial misconduct." },
          { title: "Editorial Standards",   desc: "Research on editorial practices, copy-editing, manuscript preparation, author guidelines, and quality control in journal publishing." },
          { title: "Research Integrity",    desc: "Research on research misconduct, replication, reproducibility, data sharing, and institutional responsibility for research integrity." },
          { title: "Publishing Economics",  desc: "Research on the business models, pricing structures, concentration of ownership, and market dynamics of academic publishing." },
        ].map((item) => (
          <div class="card" style="border:none;border-radius:0;">
            <h3 style="font-family:var(--font-sans);font-size:15px;font-weight:600;color:var(--text-main);margin-bottom:10px;">{item.title}</h3>
            <p style="font-size:14px;line-height:1.7;color:var(--text-secondary);">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--bg-white);border-top:1px solid var(--border-light);">
    <div class="container">
      <div class="section-label">Research Projects</div>
      <h2 class="section-title">Current Projects</h2>
      <div style="margin-top:8px;">
        {[
          { status: "Active", title: "Scholarly Publishing Standards Project", desc: "Developing editorial standards, publication ethics guidance, research integrity policies, and scholarly communication frameworks for application across academic journals and publishers.", href: "/projects/scholarly-publishing-standards" },
          { status: "Active", title: "Peer Review Models and Publication Ethics", desc: "A comparative study of peer review models across disciplines, examining effectiveness, bias, timeliness, and ethical dimensions of different review systems.", href: "/projects/scholarly-publishing-standards" },
        ].map((p) => (
          <div class="project-card" style="margin-bottom:1px;border-radius:0;border-bottom:1px solid var(--border-light);">
            <span class="tag tag-active" style="margin-bottom:12px;display:inline-flex;">{p.status}</span>
            <h3 class="project-title">{p.title}</h3>
            <p class="project-desc">{p.desc}</p>
            <a href={p.href} style="display:inline-flex;margin-top:16px;font-size:13.5px;color:var(--accent-steel);">View Project &rarr;</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
    <div class="container">
      <div class="section-label">Publications</div>
      <h2 class="section-title">Center Publications</h2>
      <div style="margin-top:8px;">
        {[
          { type: "Working Paper", title: "Peer Review Models and Publication Ethics in the Digital Age", year: "2026" },
          { type: "Policy Brief",  title: "Open Access Mandates and Their Implementation in Asia-Pacific Institutions", year: "2026" },
        ].map((pub) => (
          <div class="publication-item">
            <div class="pub-type">{pub.type}</div>
            <div class="pub-title">{pub.title}</div>
            <div style="text-align:right;">
              <div style="font-family:var(--font-mono);font-size:13px;color:var(--text-muted);margin-bottom:10px;">{pub.year}</div>
              <a href="/publications" class="btn-ghost btn" style="font-size:13px;padding:0;">Details &rarr;</a>
            </div>
          </div>
        ))}
      </div>
      <div style="margin-top:32px;">
        <a href="/publications" class="btn btn-secondary">All Publications</a>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 900px) {
  div[style*="grid-template-columns:1fr 2fr"] { display: block !important; }
  div[style*="grid-template-columns:repeat(3,1fr)"] { grid-template-columns: repeat(2,1fr) !important; }
}
@media (max-width: 600px) {
  div[style*="grid-template-columns:repeat(3,1fr)"],
  div[style*="grid-template-columns:repeat(2,1fr)"] { display: block !important; }
}
</style>
