---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const resources = [
  { cat: "Governance",   name: "Institute Charter",                 type: "PDF",  desc: "The full founding charter of Panorama Research Institute.", href: "/resources/charter-pdf" },
  { cat: "Governance",   name: "Research Ethics Statement",         type: "PDF",  desc: "The Institute's research ethics principles and guidelines.", href: "/governance/research-ethics" },
  { cat: "Templates",    name: "Research Proposal Template",        type: "DOCX", desc: "Template for submitting a research project proposal.", href: "#" },
  { cat: "Templates",    name: "Report Template",                   type: "DOCX", desc: "Standard template for Institute research reports.", href: "#" },
  { cat: "Templates",    name: "Policy Brief Template",             type: "DOCX", desc: "Template for Institute policy briefs.", href: "#" },
  { cat: "Templates",    name: "Edited Volume Proposal Template",   type: "DOCX", desc: "Template for proposing an edited volume.", href: "#" },
  { cat: "Forms",        name: "Visiting Scholar Application Form", type: "PDF",  desc: "Application form for visiting scholar positions.", href: "/collaboration/visiting-scholar-application" },
  { cat: "Forms",        name: "Research Fellow Application Form",  type: "PDF",  desc: "Application form for research fellow positions.", href: "/collaboration/research-fellow-application" },
  { cat: "Forms",        name: "Research Fellow Application Form (EN PDF)", type: "PDF", desc: "Downloadable English PDF application form for research fellow positions.", href: "/forms/PRI_Research_Fellow_Application_Form_EN.pdf", download: true },
  { cat: "Forms",        name: "Research Fellow Application Form (CN PDF)", type: "PDF", desc: "Downloadable Chinese PDF application form for research fellow positions.", href: "/forms/PRI_研究员申请表_CN.pdf", download: true },
  { cat: "Guidelines",   name: "Publication Ethics Statement",      type: "PDF",  desc: "The Institute's publication ethics and research integrity policy.", href: "/governance/publication-report-policy" },
  { cat: "Guidelines",   name: "Collaboration Guidelines",          type: "PDF",  desc: "Procedures and expectations for institutional collaboration.", href: "/governance/rules" },
  { cat: "Brand",        name: "Logo Usage Guidelines",             type: "PDF",  desc: "Guidance on authorized use of the Institute's name and logo.", href: "/governance/name-logo-usage" },
];

const categories = ["All", "Governance", "Templates", "Forms", "Guidelines", "Brand"];
---

<BaseLayout
  title="Resources"
  description="Downloads, templates, forms, guidelines, and reference documents from Panorama Research Institute."
>
  <PageHero
    title="Resources"
    description="Downloads, templates, forms, guidelines, and reference documents for researchers, collaborators, and partners."
    breadcrumbs={[{ label: "Resources" }]}
  />

  <!-- Category Filter -->
  <section style="background:var(--bg-white);border-bottom:1px solid var(--border-light);padding:20px 0;">
    <div class="container">
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        {categories.map((c, i) => (
          <button class={`tag ${i === 0 ? 'tag-active' : ''}`} style="cursor:pointer;" type="button">{c}</button>
        ))}
      </div>
    </div>
  </section>

  <!-- Resources List -->
  <section class="section" style="background:var(--bg-main);">
    <div class="container">
      {categories.slice(1).map((cat) => {
        const items = resources.filter(r => r.cat === cat);
        return (
          <div style="margin-bottom:56px;">
            <div style="display:flex;align-items:center;gap:16px;margin-bottom:24px;padding-bottom:16px;border-bottom:2px solid var(--text-main);">
              <div class="section-label" style="margin-bottom:0;">{cat}</div>
            </div>
            {items.map((r) => (
              <div style="display:grid;grid-template-columns:1fr auto;gap:24px;padding:20px 0;border-bottom:1px solid var(--border-light);align-items:center;">
                <div>
                  <div style="display:flex;align-items:center;gap:12px;margin-bottom:6px;">
                    <h3 style="font-family:var(--font-sans);font-size:15.5px;font-weight:600;color:var(--text-main);">{r.name}</h3>
                    <span class="tag" style="font-family:var(--font-mono);font-size:10px;">{r.type}</span>
                  </div>
                  <p style="font-size:13.5px;color:var(--text-secondary);">{r.desc}</p>
                </div>
                <a href={r.href} target={r.external ? '_blank' : undefined} rel={r.external ? 'noopener' : undefined} download={r.download ? true : undefined} class="btn btn-secondary" style="white-space:nowrap;font-size:12.5px;padding:8px 16px;">
                  {r.type === 'DOCX' || r.download ? 'Download' : 'View'}
                </a>
              </div>
            ))}
          </div>
        );
      })}
    </div>
  </section>

  <!-- Request Resources -->
  <section class="section-compact" style="background:var(--bg-white);border-top:1px solid var(--border-light);">
    <div class="container">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap;">
        <div>
          <h2 style="font-family:var(--font-serif);font-size:22px;color:var(--text-main);margin-bottom:8px;">Need a resource not listed here?</h2>
          <p style="font-size:14.5px;color:var(--text-secondary);">Contact the Institute to request additional templates, forms, or guidance documents.</p>
        </div>
        <a href="/contact" class="btn btn-primary">Contact the Institute</a>
      </div>
    </div>
  </section>
</BaseLayout>
