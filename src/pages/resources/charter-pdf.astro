---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="Institute Charter (PDF)" description="Download the Panorama Research Institute Charter in PDF format.">
  <PageHero
    title="Institute Charter (PDF)"
    description="The Panorama Research Institute Charter is available for download in PDF format. The Charter is the Institute's founding governance document."
    breadcrumbs={[{ label: "Resources", href: "/resources" }, { label: "Charter PDF" }]}
  />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div style="max-width:760px;">
        <div style="border:1px solid var(--border-light);padding:40px;margin-bottom:40px;display:flex;gap:40px;align-items:flex-start;">
          <div style="flex-shrink:0;width:64px;height:80px;background:var(--accent-steel);display:flex;align-items:center;justify-content:center;">
            <span style="font-family:var(--font-mono);font-size:10px;color:rgba(255,255,255,0.85);letter-spacing:0.1em;text-transform:uppercase;writing-mode:vertical-rl;transform:rotate(180deg);">PDF</span>
          </div>
          <div style="flex:1;">
            <div style="font-family:var(--font-mono);font-size:11px;text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:8px;">Governance Document</div>
            <h2 style="font-family:var(--font-serif);font-size:22px;color:var(--text-main);margin-bottom:8px;font-weight:400;">Charter of Panorama Research Institute</h2>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin:20px 0;">
              {[
                { label:"Document Type",  value:"Institute Charter" },
                { label:"Version",        value:"1.0 (2026)" },
                { label:"Language",       value:"English" },
                { label:"Format",         value:"PDF" },
                { label:"Articles",       value:"20" },
                { label:"Access",         value:"Open" },
              ].map((item) => (
                <div>
                  <div style="font-size:10px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:3px;">{item.label}</div>
                  <div style="font-size:13.5px;color:var(--text-main);">{item.value}</div>
                </div>
              ))}
            </div>
            <div style="display:flex;gap:10px;margin-top:24px;">
              <a href="/charter" class="btn btn-primary">Read Online</a>
              <a href="/charter" class="btn btn-secondary">Download PDF</a>
            </div>
          </div>
        </div>

        <h2 style="font-family:var(--font-serif);font-size:22px;color:var(--text-main);margin-bottom:14px;font-weight:400;">About the Charter</h2>
        <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:20px;">
          The Charter of Panorama Research Institute is the Institute's founding governance document. It establishes the Institute's name, mission, structure, research areas, operational principles, and governance framework. The Charter is adopted under the authority of Panorama Scholarly Group and constitutes the primary constitutional document of the Institute.
        </p>
        <p style="font-size:16px;line-height:1.85;color:var(--text-secondary);margin-bottom:32px;">
          The Charter consists of 20 articles covering the Institute's legal status, mission and vision, research areas, organizational structure, governance bodies, research ethics, publication policies, collaboration framework, scholar programs, and amendment procedures. It should be read in conjunction with the Institute's subsidiary governance policies.
        </p>

        <div style="display:flex;gap:10px;flex-wrap:wrap;">
          <a href="/charter" class="btn btn-primary">Read the Charter Online</a>
          <a href="/governance/rules" class="btn btn-secondary">Governance Rules</a>
          <a href="/resources" class="btn btn-secondary">All Resources</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 600px) {
  div[style*="grid-template-columns:repeat(3,1fr)"] { grid-template-columns: repeat(2,1fr) !important; }
  div[style*="display:flex;gap:40px"] { display: block !important; }
}
</style>
