---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getSecondaryStaticPaths } from '../../i18n/secondaryPages';

export function getStaticPaths() {
  return getSecondaryStaticPaths('zh-cn');
}

const { page, slug } = Astro.props;
const englishHref = `/${slug}`;
---

<BaseLayout title={page.title} description={page.description} lang="zh-cn">
  <PageHero
    title={page.title}
    description={page.description}
    breadcrumbs={[{ label: page.eyebrow }, { label: page.title }]}
    tag={page.eyebrow}
    homeLabel="首页"
    homeHref="/zh-cn"
  />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div style="display:grid;grid-template-columns:240px 1fr;gap:64px;align-items:start;">
        <aside style="position:sticky;top:calc(var(--nav-height) + 24px);border-top:1px solid var(--border-light);">
          <a href="/zh-cn" style="display:block;padding:14px 0;border-bottom:1px solid var(--border-light);font-size:13px;color:var(--text-secondary);">首页</a>
          <a href={`/${slug.split('/')[0]}`} style="display:block;padding:14px 0;border-bottom:1px solid var(--border-light);font-size:13px;color:var(--text-secondary);">英文栏目</a>
          <a href={englishHref} style="display:block;padding:14px 0;border-bottom:1px solid var(--border-light);font-size:13px;color:var(--accent-steel);">英文原页</a>
        </aside>

        <div>
          <div class="section-label">{page.eyebrow}</div>
          <h2 style="font-family:var(--font-serif);font-size:30px;color:var(--text-main);margin-bottom:18px;font-weight:400;">{page.title}</h2>
          <p style="font-size:16px;line-height:1.8;color:var(--text-secondary);max-width:760px;margin-bottom:40px;">{page.description}</p>

          <div style="display:flex;flex-direction:column;gap:0;max-width:820px;">
            {page.sections.map((section, i) => (
              <div style="display:grid;grid-template-columns:64px 1fr;gap:24px;padding:26px 0;border-top:1px solid var(--border-light);">
                <div style="font-family:var(--font-mono);font-size:12px;color:var(--text-muted);padding-top:5px;">{String(i + 1).padStart(2, '0')}</div>
                <div>
                  <h3 style="font-size:17px;font-weight:600;color:var(--text-main);margin-bottom:10px;">{section.title}</h3>
                  <p style="font-size:15.5px;line-height:1.85;color:var(--text-secondary);">{section.body}</p>
                </div>
              </div>
            ))}
          </div>

          <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:36px;">
            <a href="/zh-cn/contact" class="btn btn-primary">联系我们</a>
            <a href={englishHref} class="btn btn-secondary">查看英文原页</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
@media (max-width: 900px) {
  div[style*="grid-template-columns:240px 1fr"],
  div[style*="grid-template-columns:64px 1fr"] { display: block !important; }
  aside { display: none !important; }
}
</style>
