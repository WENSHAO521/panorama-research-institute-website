---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="关于研究院" description="全景研究院简介、使命、机构性质与治理框架。" lang="zh-cn">
  <PageHero
    title="关于全景研究院"
    description="全景研究院是全景学术集团的内部研究与学术发展部门，致力于推动跨学科研究、学术出版研究、期刊索引与评价及政策分析。"
    breadcrumbs={[{ label: "研究院" }]}
    homeLabel="首页" homeHref="/zh-cn"
  />

  <!-- Overview -->
  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 2fr;gap:64px;align-items:start;">
        <div>
          <div class="section-label">机构简介</div>
          <h2 style="font-family:var(--font-serif);font-size:28px;color:var(--text-main);font-weight:400;line-height:1.3;">
            独立学术平台
          </h2>
        </div>
        <div>
          <p style="font-size:17px;line-height:1.85;color:var(--text-secondary);margin-bottom:24px;">
            全景研究院（Panorama Research Institute）是全景学术集团的内部研究与学术发展部门，不具备独立法人资格。研究院在研究工作、出版决策及学术事务上保持充分的学术独立性，同时接受全景学术集团的行政管理与治理监督。
          </p>
          <p style="font-size:17px;line-height:1.85;color:var(--text-secondary);">
            研究院支持跨学科研究，推动学术出版研究、期刊索引与评价、政策分析、学术合作及全球学术传播基础设施建设。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="section" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:64px;">
        <div>
          <div class="section-label">使命</div>
          <h2 style="font-family:var(--font-serif);font-size:26px;color:var(--text-main);margin-bottom:16px;font-weight:400;">
            通过严谨研究推动学术知识进步，促进开放的学术传播
          </h2>
          <p style="font-size:16px;line-height:1.8;color:var(--text-secondary);">
            全景研究院致力于开展严谨、独立、具有公共价值的研究，在各研究领域推动知识进步，支持学者和研究团队，并构建强化全球学术传播的基础设施。
          </p>
        </div>
        <div>
          <div class="section-label">愿景</div>
          <h2 style="font-family:var(--font-serif);font-size:26px;color:var(--text-main);margin-bottom:16px;font-weight:400;">
            成为跨学科学术探究的可信平台
          </h2>
          <p style="font-size:16px;line-height:1.8;color:var(--text-secondary);">
            研究院希望建立一个研究基础设施、学术出版与学术合作均透明、公平且面向全球开放的未来，并成为研究人员、机构及政策制定者信赖的学术平台。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Institutional Status -->
  <section class="section" style="background:var(--bg-white);border-top:1px solid var(--border-light);">
    <div class="container">
      <div class="section-label">机构性质</div>
      <h2 class="section-title">法律与机构地位</h2>
      <div style="max-width:760px;">
        <div class="statement-box" style="margin-bottom:32px;">
          <p style="font-size:16px;line-height:1.75;color:var(--text-secondary);margin:0;">
            全景研究院不具备独立法人资格，依托全景学术集团的治理体系与行政管理框架运作。
          </p>
        </div>
        <p style="font-size:16px;line-height:1.8;color:var(--text-secondary);">
          研究院作为全景学术集团的内部学术部门，在研究、出版及学术活动方面保持运营独立性，同时接受全景学术集团治理框架与行政管理的监督。所有正式协议、合同及法律文件均由全景学术集团代表研究院签署执行。
        </p>
      </div>
    </div>
  </section>

  <!-- Research Areas Quick View -->
  <section class="section" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
    <div class="container">
      <div class="section-label">研究领域</div>
      <h2 class="section-title">六大研究领域</h2>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border-light);border:1px solid var(--border-light);margin-top:8px;">
        {[
          { num:"I",   name:"学术出版研究",       desc:"开放获取、同行评审、出版伦理、编辑标准及学术传播实践。" },
          { num:"II",  name:"学术索引与评价研究", desc:"期刊索引体系、引文指标、期刊质量框架及数据库透明度。" },
          { num:"III", name:"政策与社会研究",     desc:"高等教育政策、科技治理、社会治理及数字治理的政策维度。" },
          { num:"IV",  name:"人工智能与未来社会", desc:"人工智能治理、AI伦理、人机交互及AI对学术传播的影响。" },
          { num:"V",   name:"教育与学习研究",     desc:"教育体制、教学法、学习科学、教育政策及技术在学习中的应用。" },
          { num:"VI",  name:"艺术、文化与具身研究", desc:"艺术实践、文化研究、具身认知、创意探索及艺术与社会研究的交叉。" },
        ].map((a) => (
          <div class="card" style="border-radius:0;border:none;">
            <div style="font-family:var(--font-mono);font-size:12px;color:var(--text-muted);margin-bottom:8px;">{a.num}</div>
            <div style="font-size:15px;font-weight:600;color:var(--text-main);margin-bottom:8px;">{a.name}</div>
            <p style="font-size:14px;color:var(--text-secondary);line-height:1.65;">{a.desc}</p>
          </div>
        ))}
      </div>
      <div style="margin-top:24px;">
        <a href="/zh-cn/research-areas" class="btn btn-primary">了解研究领域</a>
      </div>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="section-compact" style="background:var(--bg-white);border-top:1px solid var(--border-light);">
    <div class="container">
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/zh-cn/charter"          class="btn btn-primary">研究院章程</a>
        <a href="/zh-cn/framework"        class="btn btn-secondary">研究院框架</a>
        <a href="/zh-cn/research-centers" class="btn btn-secondary">研究中心</a>
        <a href="/zh-cn/contact"          class="btn btn-secondary">联系我们</a>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 768px) {
  div[style*="grid-template-columns:1fr 2fr"],
  div[style*="grid-template-columns:1fr 1fr"],
  div[style*="grid-template-columns:repeat(3,1fr)"] { display: block !important; }
}
</style>
