---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="合作" description="与全景研究院开展学术合作、机构合作及研究员申请的途径。" lang="zh-cn">
  <PageHero title="合作" description="全景研究院欢迎来自全球学术机构、研究组织及学术出版社的合作申请，共同推进研究院核心研究领域的学术发展。" breadcrumbs={[{ label: "合作" }]} homeLabel="首页" homeHref="/zh-cn" />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div class="section-label">合作形式</div>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--border-light);border:1px solid var(--border-light);margin-top:8px;">
        {[
          { title:"研究员申请", en:"研究员申请", href:"/collaboration/research-fellow-application", desc:"学者可申请全景研究院研究员、副研究员及访问学者职位，以正式成员身份参与研究院学术项目与出版活动。研究员申请全年开放，随时接受。" },
          { title:"学术机构合作", en:"学术机构合作", href:"/collaboration/institutional", desc:"大学、研究中心及学术机构可与研究院签署正式合作协议，建立共同研究项目、学者交流及联合出版等合作框架。" },
          { title:"访问学者申请", en:"访问学者申请", href:"/collaboration/visiting-scholar-application", desc:"成熟研究人员可申请短期或长期驻院访问研究，参与特定研究项目，在研究院国际研究网络中开展学术合作。访问期通常为三至十二个月。" },
          { title:"学术出版合作", en:"学术出版合作", href:"/collaboration/publishing", desc:"学术出版社及期刊可就联合出版、编辑合作或学术文集开发项目与研究院开展合作，共同推进学术出版标准与开放获取实践。" },
          { title:"会议与活动合作", en:"会议与活动合作", href:"/collaboration/events", desc:"研究机构、学术学会及大学可就学术会议、研讨会及工作坊与研究院开展合作共同举办，共同推动特定研究领域的学术交流。" },
          { title:"研究合作提案", en:"研究合作提案", href:"/collaboration/research-proposal", desc:"来自其他机构的研究人员可向研究院提交联合研究提案。研究院根据研究主题与核心研究领域的契合程度及资源情况评估合作可行性。" },
        ].map((item) => (
          <a href={item.href} class="card" style="border-radius:0;border:none;display:block;">
            <div style="font-size:16px;font-weight:600;color:var(--text-main);margin-bottom:4px;">{item.title}</div>
            <div style="font-size:11px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:10px;">{item.en}</div>
            <p style="font-size:14px;color:var(--text-secondary);line-height:1.65;">{item.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
    <div class="container">
      <div style="max-width:680px;">
        <div class="section-label">合作原则</div>
        <h2 style="font-family:var(--font-serif);font-size:26px;color:var(--text-main);margin-bottom:20px;font-weight:400;">我们的合作立场</h2>
        <div style="display:flex;flex-direction:column;gap:0;">
          {[
            { title:"学术独立",  desc:"所有合作均须尊重研究院的学术独立性。合作方不得以任何方式影响研究成果、出版决定或学术立场。" },
            { title:"开放获取",  desc:"研究院的研究成果依照开放获取原则发布，合作协议须支持这一原则，或明确约定例外安排。" },
            { title:"研究伦理",  desc:"合作研究须遵守研究院研究伦理政策，包括研究诚信、利益冲突披露及数据管理标准。" },
            { title:"透明度",   desc:"涉及外部资助的合作须在研究成果发布时予以明确披露。" },
          ].map((p) => (
            <div style="display:grid;grid-template-columns:160px 1fr;gap:24px;padding:18px 0;border-bottom:1px solid var(--border-light);">
              <div style="font-size:15px;font-weight:600;color:var(--text-main);">{p.title}</div>
              <p style="font-size:14.5px;color:var(--text-secondary);line-height:1.7;margin:0;">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-compact" style="background:var(--bg-dark);">
    <div class="container">
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:24px;">
        <div>
          <h2 style="font-family:var(--font-serif);font-size:24px;color:#fff;margin-bottom:8px;font-weight:400;">立即开始合作洽谈</h2>
          <p style="font-size:15px;color:rgba(255,255,255,0.6);margin:0;">如有合作意向，欢迎通过联系页面与研究院取得联系。</p>
        </div>
        <div style="display:flex;gap:12px;flex-wrap:wrap;">
          <a href="/zh-cn/contact" class="btn btn-primary">联系研究院</a>
          <a href="/collaboration"  class="btn btn-secondary" style="color:#fff;border-color:rgba(255,255,255,0.3);">合作详情（英文）</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 768px) {
  div[style*="grid-template-columns:repeat(2,1fr)"],
  div[style*="grid-template-columns:160px 1fr"] { display: block !important; }
}
</style>
