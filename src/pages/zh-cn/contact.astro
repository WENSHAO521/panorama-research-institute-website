---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="联系" description="联系全景研究院的方式，包括一般咨询、合作申请及媒体联系。" lang="zh-cn">
  <PageHero title="联系" description="如需了解研究合作、研究员申请、出版查询或一般学术事务，欢迎通过以下方式联系全景研究院。" breadcrumbs={[{ label: "联系" }]} homeLabel="首页" homeHref="/zh-cn" />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 320px;gap:80px;align-items:start;">

        <!-- Contact types -->
        <div>
          <div class="section-label">联系方式</div>
          <div style="display:flex;flex-direction:column;gap:0;margin-top:8px;">
            {[
              { type:"一般咨询",       en:"General Inquiries",      href:"/contact",                          desc:"关于研究院的一般性问题，包括研究活动、出版物及机构信息查询。", email:"contact@panoramaresearch.org" },
              { type:"学术合作申请",   en:"Research Collaboration",  href:"/collaboration",                    desc:"机构合作、联合研究项目及访问学者申请等学术合作事务。", email:"collaboration@panoramaresearch.org" },
              { type:"出版查询",       en:"Publication Inquiries",   href:"/publications",                     desc:"投稿须知、稿件状态、引用许可及出版物相关事务。", email:"publications@panoramaresearch.org" },
              { type:"媒体与新闻",     en:"Media & Press",           href:"/contact/media",                    desc:"媒体采访申请、研究发现引用及新闻发布相关事务。", email:"media@panoramaresearch.org" },
              { type:"研究员项目",     en:"Fellowship Program",      href:"/collaboration/research-fellow-application", desc:"研究员、副研究员及访问学者职位申请查询。", email:"fellowship@panoramaresearch.org" },
            ].map((item) => (
              <div style="display:grid;grid-template-columns:180px 1fr;gap:24px;padding:20px 0;border-bottom:1px solid var(--border-light);align-items:start;">
                <div>
                  <div style="font-size:15px;font-weight:600;color:var(--text-main);margin-bottom:3px;">{item.type}</div>
                  <div style="font-size:11px;color:var(--text-muted);font-family:var(--font-mono);">{item.en}</div>
                </div>
                <div>
                  <p style="font-size:14.5px;color:var(--text-secondary);line-height:1.65;margin-bottom:8px;">{item.desc}</p>
                  <a href={`mailto:${item.email}`} style="font-size:13px;font-family:var(--font-mono);color:var(--accent-steel);">{item.email}</a>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Sidebar -->
        <div style="padding:28px;background:var(--bg-main);border:1px solid var(--border-light);">
          <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-muted);margin-bottom:16px;">机构信息</div>
          <div style="display:flex;flex-direction:column;gap:16px;">
            <div>
              <div style="font-size:12px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:4px;">机构全称</div>
              <div style="font-size:14px;color:var(--text-main);line-height:1.5;">全景研究院<br/><span style="color:var(--text-secondary);font-size:13px;">Panorama Research Institute</span></div>
            </div>
            <div>
              <div style="font-size:12px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:4px;">所属机构</div>
              <div style="font-size:14px;color:var(--text-main);">全景学术集团<br/><span style="color:var(--text-secondary);font-size:13px;">Panorama Scholarly Group</span></div>
            </div>
            <div>
              <div style="font-size:12px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:4px;">成立年份</div>
              <div style="font-size:14px;color:var(--text-main);">2026</div>
            </div>
            <div>
              <div style="font-size:12px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:4px;">运营模式</div>
              <div style="font-size:14px;color:var(--text-main);">全球数字化运营<br/><span style="color:var(--text-secondary);font-size:13px;">无固定实体地址</span></div>
            </div>
            <div>
              <div style="font-size:12px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:4px;">通用联系邮箱</div>
              <a href="mailto:contact@panoramaresearch.org" style="font-size:13px;font-family:var(--font-mono);color:var(--accent-steel);">contact@panoramaresearch.org</a>
            </div>
          </div>

          <div style="margin-top:28px;padding-top:20px;border-top:1px solid var(--border-light);">
            <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-muted);margin-bottom:12px;">回复时限</div>
            <p style="font-size:13.5px;color:var(--text-secondary);line-height:1.65;margin:0;">
              一般查询通常在五个工作日内回复。合作申请可能需要较长的评估周期，研究院将在收到申请后三至四周内作出初步回应。
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="section-compact" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
    <div class="container">
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/zh-cn/collaboration" class="btn btn-primary">合作申请</a>
        <a href="/zh-cn/people"        class="btn btn-secondary">研究员项目</a>
        <a href="/contact"             class="btn btn-secondary">联系页面（英文）</a>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 900px) {
  div[style*="grid-template-columns:1fr 320px"] { display: block !important; }
  div[style*="grid-template-columns:180px 1fr"] { display: block !important; }
}
</style>
