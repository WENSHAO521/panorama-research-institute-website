---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="学术活动" description="全景研究院组织的学术会议、研讨会、工作坊及征稿活动。" lang="zh-cn">
  <PageHero title="学术活动" description="全景研究院通过组织多种形式的学术活动，推动各研究领域内的学术交流与共同体建设。" breadcrumbs={[{ label: "活动" }]} homeLabel="首页" homeHref="/zh-cn" />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div class="statement-box" style="max-width:720px;margin-bottom:48px;">
        <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-muted);margin-bottom:10px;">活动说明</div>
        <p style="font-size:15.5px;line-height:1.8;color:var(--text-secondary);margin:0;">
          全景研究院成立于2026年，正处于创建奠基阶段。研究院的首批学术活动正在策划中，将在研究中心和研究项目具备充分的研究成果积累后陆续举办。
        </p>
      </div>
      <div class="section-label" style="margin-bottom:32px;">活动类型</div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border-light);border:1px solid var(--border-light);">
        {[
          { type:"学术会议", en:"Conferences",      href:"/events/conferences",      desc:"聚焦研究院核心研究领域的国际学术会议，接受原创研究论文，经同行评审遴选发言人。" },
          { type:"学术研讨会", en:"Seminars",        href:"/events/seminars",          desc:"小型专题研讨会，邀请研究院学者及访问研究人员就特定研究议题深入交流。" },
          { type:"研究工作坊", en:"Workshops",       href:"/events/workshops",         desc:"以实践为导向的小型学术工作坊，聚焦方法论、研究设计或具体研究议题。" },
          { type:"培训项目", en:"Training Programs", href:"/events/training-programs",desc:"面向期刊编辑、研究人员及学术实践者的能力建设培训项目。" },
          { type:"征稿启事", en:"Calls for Papers",  href:"/events/calls-for-papers", desc:"面向会议和特刊的学术论文征集公告，欢迎符合研究领域的原创投稿。" },
          { type:"征集书稿", en:"Calls for Chapters",href:"/events/calls-for-chapters",desc:"面向研究院主编学术文集的书稿征集公告，欢迎学术界同仁参与投稿。" },
        ].map((item) => (
          <a href={item.href} class="card" style="border-radius:0;border:none;display:block;">
            <div style="font-size:16px;font-weight:600;color:var(--text-main);margin-bottom:4px;">{item.type}</div>
            <div style="font-size:11px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:10px;">{item.en}</div>
            <p style="font-size:14px;color:var(--text-secondary);line-height:1.65;">{item.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-compact" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
    <div class="container">
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/events/calls-for-papers"   class="btn btn-primary">征稿启事（英文）</a>
        <a href="/events/calls-for-chapters" class="btn btn-secondary">征集书稿（英文）</a>
        <a href="/zh-cn/collaboration"        class="btn btn-secondary">活动合作申请</a>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 768px) {
  div[style*="grid-template-columns:repeat(3,1fr)"] { display: block !important; }
}
</style>
