---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="全景研究院"
  description="全景研究院是全景学术集团的内部研究与学术发展部门，致力于推动跨学科研究、学术出版、期刊索引与评价及政策分析。"
  lang="zh-cn"
>

<!-- ── 01 Hero ── -->
<section style="background:var(--bg-dark);padding:120px 0 96px;position:relative;overflow:hidden;">
  <div class="container" style="position:relative;z-index:1;">
    <div style="max-width:780px;">
      <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.16em;text-transform:uppercase;color:rgba(255,255,255,0.45);margin-bottom:32px;">
        全景学术集团 · 研究与学术发展部门
      </div>
      <h1 style="font-family:var(--font-serif);font-size:clamp(40px,6vw,72px);color:#fff;line-height:1.1;letter-spacing:-0.02em;margin-bottom:32px;font-weight:400;">
        全景研究院
      </h1>
      <p style="font-size:18px;line-height:1.75;color:rgba(255,255,255,0.7);max-width:600px;margin-bottom:48px;">
        独立学术研究平台，专注于跨学科研究、学术出版研究、期刊索引与评价、政策分析及学术传播基础设施建设。
      </p>
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/zh-cn/research-centers" class="btn btn-primary">研究中心</a>
        <a href="/zh-cn/about"             class="btn btn-secondary" style="color:#fff;border-color:rgba(255,255,255,0.25);">关于研究院</a>
      </div>
    </div>
  </div>
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(55,90,107,0.15) 0%,transparent 60%);pointer-events:none;"></div>
</section>

<!-- ── 02 About Snapshot ── -->
<section class="section" style="background:var(--bg-white);border-bottom:1px solid var(--border-light);">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 2fr;gap:64px;align-items:start;">
      <div>
        <div class="section-label">关于研究院</div>
        <h2 style="font-family:var(--font-serif);font-size:28px;color:var(--text-main);margin-bottom:0;font-weight:400;line-height:1.3;">
          独立从事学术研究，严守学术标准
        </h2>
      </div>
      <div>
        <p style="font-size:17px;line-height:1.85;color:var(--text-secondary);margin-bottom:24px;">
          全景研究院是全景学术集团的内部研究与学术发展部门，不具备独立法人资格。研究院在研究工作、出版决策及学术事务上保持充分的学术独立性，同时接受全景学术集团的行政管理与治理监督。
        </p>
        <p style="font-size:17px;line-height:1.85;color:var(--text-secondary);">
          研究院致力于在指定研究领域开展严谨、跨学科的原创研究；支持全球学术传播基础设施的发展；促进学术出版与科研实践中的开放性、透明度与诚信精神。
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ── 03 Institutional Statement ── -->
<section class="section" style="background:var(--bg-main);">
  <div class="container">
    <div style="max-width:680px;margin:0 auto;text-align:center;">
      <div style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:var(--text-muted);margin-bottom:24px;">机构声明</div>
      <h2 style="font-family:var(--font-serif);font-size:22px;color:var(--text-main);margin-bottom:20px;font-weight:400;line-height:1.5;">
        An Academic Platform within Panorama Scholarly Group
      </h2>
      <p style="font-size:15.5px;line-height:1.7;color:var(--text-secondary);margin-bottom:10px;">
        Panorama Research Institute operates as an independent academic platform under the governance of Panorama Scholarly Group. It is an internal research and academic development division and is not a separate legal entity.
      </p>
      <div style="margin-top:24px;display:flex;gap:10px;flex-wrap:wrap;justify-content:center;">
        <a href="/zh-cn/about"   class="btn btn-secondary">了解更多</a>
        <a href="/zh-cn/charter" class="btn btn-secondary">研究院章程</a>
      </div>
    </div>
  </div>
</section>

<!-- ── 04 Research Centers ── -->
<section class="section" style="background:var(--bg-white);border-top:1px solid var(--border-light);">
  <div class="container">
    <div style="margin-bottom:48px;">
      <div class="section-label">研究中心</div>
      <h2 class="section-title">当前研究领域</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--border-light);border:1px solid var(--border-light);">
      {[
        { num:"01", name:"学术出版研究中心",       en:"Center for Scholarly Publishing Studies",      status:"进行中", desc:"研究开放获取模式、同行评审制度、出版伦理及学术传播体系的演变。" },
        { num:"02", name:"学术索引与评价研究中心", en:"Center for Scholarly Indexing and Evaluation", status:"进行中", desc:"研究期刊索引体系、引文指标、期刊质量框架及数据库透明度问题。" },
        { num:"03", name:"政策与社会研究中心",     en:"Center for Policy and Social Research",         status:"进行中", desc:"研究高等教育政策、科学治理、社会治理及数字治理的政策维度。" },
        { num:"04", name:"人工智能与未来社会研究中心","en":"Center for AI and Future Society",          status:"即将开展", desc:"研究人工智能治理、AI伦理、人机交互及AI对学术传播的影响。" },
      ].map((c) => (
        <div class="card" style="border-radius:0;border:none;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
            <span style="font-family:var(--font-mono);font-size:11px;color:var(--text-muted);">{c.num}</span>
            <span class={`tag ${c.status === '进行中' ? 'tag-active' : 'tag-steel'}`}>{c.status}</span>
          </div>
          <h3 style="font-family:var(--font-serif);font-size:18px;color:var(--text-main);margin-bottom:4px;font-weight:400;">{c.name}</h3>
          <div style="font-size:12px;color:var(--text-muted);margin-bottom:12px;">{c.en}</div>
          <p style="font-size:14px;line-height:1.65;color:var(--text-secondary);">{c.desc}</p>
        </div>
      ))}
    </div>
    <div style="margin-top:24px;">
      <a href="/zh-cn/research-centers" class="btn btn-primary">查看全部研究中心</a>
    </div>
  </div>
</section>

<!-- ── 05 Current Projects ── -->
<section class="section" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 2fr;gap:64px;align-items:start;">
      <div>
        <div class="section-label">当前项目</div>
        <h2 style="font-family:var(--font-serif);font-size:28px;color:var(--text-main);margin-bottom:16px;font-weight:400;">
          进行中的研究项目
        </h2>
        <a href="/zh-cn/projects" class="btn btn-primary">查看全部项目</a>
      </div>
      <div style="display:flex;flex-direction:column;gap:0;">
        {[
          { num:"01", name:"全景开放学术索引项目（POSI）", status:"待上线", desc:"数据库已开发完毕，正在等待正式上线；平台将提供透明、全面、方法严谨的学术期刊开放索引信息。" },
          { num:"02", name:"第十五个五年规划研究",         status:"进行中", desc:"系统研究中国第十五个五年规划（2026—2030）对高等教育与科学政策的影响。" },
          { num:"03", name:"人工智能与未来社会研究",       status:"开发中", desc:"研究人工智能治理、伦理及其对学术传播与知识生产的影响。" },
          { num:"04", name:"青少年数字治理研究",           status:"进行中", desc:"研究数字治理框架对青少年数字环境与权益保护的影响。" },
        ].map((p) => (
          <div style="display:grid;grid-template-columns:32px 1fr auto;gap:16px;padding:16px 0;border-bottom:1px solid var(--border-light);align-items:start;">
            <span style="font-family:var(--font-mono);font-size:11px;color:var(--text-muted);padding-top:2px;">{p.num}</span>
            <div>
              <div style="font-size:15px;font-weight:600;color:var(--text-main);margin-bottom:4px;">{p.name}</div>
              <div style="font-size:13.5px;color:var(--text-secondary);line-height:1.6;">{p.desc}</div>
            </div>
            <span class={`tag ${p.status === '进行中' ? 'tag-active' : 'tag-steel'}`} style="flex-shrink:0;">{p.status}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ── 06 Publications ── -->
<section class="section" style="background:var(--bg-white);border-top:1px solid var(--border-light);">
  <div class="container">
    <div class="section-label">出版物</div>
    <h2 class="section-title">出版物类型</h2>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border-light);border:1px solid var(--border-light);margin-top:8px;">
      {[
        { type:"研究报告",   en:"Research Reports",   desc:"呈现原创研究成果的全长报告，经内部评审与外部同行评审。" },
        { type:"工作论文",   en:"Working Papers",     desc:"呈现初步研究发现或理论框架的简短学术文章，经内部编辑评审。" },
        { type:"政策简报",   en:"Policy Briefs",      desc:"基于证据的简洁文件，向决策者呈现研究发现与政策建议。" },
        { type:"主编学术文集", en:"Edited Volumes",   desc:"多位学者围绕特定主题合作撰写的学术文集，与学术出版社合作出版。" },
        { type:"年度报告",   en:"Annual Reports",     desc:"年度机构报告，全面记录研究院的研究活动、出版物、活动及治理情况。" },
        { type:"指南与标准", en:"Guidelines",         desc:"基于研究成果开发，供期刊、出版社及学术机构参考使用的实用标准文件。" },
      ].map((item) => (
        <div class="card" style="border-radius:0;border:none;">
          <div style="font-size:16px;font-weight:600;color:var(--text-main);margin-bottom:4px;">{item.type}</div>
          <div style="font-size:11px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:12px;">{item.en}</div>
          <p style="font-size:14px;color:var(--text-secondary);line-height:1.65;">{item.desc}</p>
        </div>
      ))}
    </div>
    <div style="margin-top:24px;">
      <a href="/zh-cn/publications" class="btn btn-primary">出版物总览</a>
    </div>
  </div>
</section>

<!-- ── 07 Collaboration CTA ── -->
<section class="section" style="background:var(--bg-dark);">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;">
      <div>
        <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.45);margin-bottom:20px;">合作机会</div>
        <h2 style="font-family:var(--font-serif);font-size:32px;color:#fff;margin-bottom:16px;font-weight:400;line-height:1.3;">
          与全景研究院开展合作
        </h2>
        <p style="font-size:16px;color:rgba(255,255,255,0.65);line-height:1.75;">
          研究院欢迎来自学术机构、研究人员及出版机构的合作申请，合作形式包括机构合作、研究项目、学术文集联合主编、研讨会及学者交流。
        </p>
      </div>
      <div style="display:flex;flex-direction:column;gap:12px;">
        {[
          { label:"申请成为研究员",   href:"/collaboration/research-fellow-application" },
          { label:"申请成为访问学者", href:"/collaboration/visiting-scholar-application" },
          { label:"提交研究项目方案", href:"/collaboration/research-project-proposal" },
          { label:"机构合作洽谈",     href:"/collaboration/institutional-cooperation" },
        ].map((item) => (
          <a href={item.href} style="display:flex;justify-content:space-between;align-items:center;padding:14px 20px;border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.8);font-size:14.5px;transition:border-color 0.15s,color 0.15s;">
            <span>{item.label}</span>
            <span style="font-size:16px;">→</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style>
@media (max-width: 768px) {
  div[style*="grid-template-columns:1fr 2fr"],
  div[style*="grid-template-columns:repeat(2,1fr)"],
  div[style*="grid-template-columns:repeat(3,1fr)"],
  div[style*="grid-template-columns:1fr 1fr"],
  div[style*="grid-template-columns:32px 1fr auto"] { display: block !important; }
}
</style>
