---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="研究项目" description="全景研究院现有研究项目。" lang="zh-cn">
  <PageHero title="研究项目" description="全景研究院现有研究项目，由各研究中心主持开展，采用开放获取原则发布研究成果。" breadcrumbs={[{ label: "研究" }]} homeLabel="首页" homeHref="/zh-cn" />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div class="section-label" style="margin-bottom:32px;">当前项目</div>
      <div style="display:flex;flex-direction:column;gap:0;">
        {[
          { num:"01", name:"全景开放学术索引项目（POSI）", en:"全景开放学术索引项目（POSI）", status:"待上线", center:"学术索引与评价研究中心", start:"2026", href:"/projects/posi-scholarly-indexing", desc:"旗舰研究与基础设施建设项目。POSI数据库已开发完毕，正在等待正式上线；平台将提供透明、全面、方法严谨的学术期刊开放索引信息。" },
          { num:"02", name:"第十五个五年规划研究",         en:"第十五个五年规划研究", status:"进行中", center:"政策与社会研究中心", start:"2026", href:"/projects/fifteenth-five-year-plan-studies", desc:"系统研究中国第十五个五年规划（2026—2030），深入分析其对高等教育体制、科学研究优先领域及社会政策发展的影响与启示。" },
          { num:"03", name:"学术出版标准研究项目",         en:"学术出版标准研究项目", status:"进行中", center:"学术出版研究中心", start:"2026", href:"/projects/scholarly-publishing-standards", desc:"系统梳理和分析学术出版领域的现行标准与规范，涵盖同行评审、编辑伦理、数据共享及作者贡献的声明标准，并研究这些标准在全球范围内的实施现状与改进路径。" },
          { num:"04", name:"青少年数字治理研究",           en:"青少年数字治理研究", status:"进行中", center:"政策与社会研究中心", start:"2026", href:"/projects/youth-digital-governance", desc:"研究数字治理框架对青少年数字生活环境的影响，关注平台监管、内容审核、数字权利保护及青少年网络安全政策的有效性与局限性。" },
          { num:"05", name:"人工智能与未来社会研究",       en:"人工智能与未来社会研究", status:"开发中", center:"人工智能与未来社会研究中心", start:"2026", href:"/projects/ai-future-society", desc:"研究人工智能治理、伦理规范及AI对学术传播与知识生产的影响，探讨AI时代学术诚信、知识生产模式与人机协作的未来走向。" },
        ].map((p) => (
          <div style="display:grid;grid-template-columns:56px 1fr 160px;gap:32px;padding:36px 0;border-bottom:1px solid var(--border-light);align-items:start;">
            <span style="font-family:var(--font-mono);font-size:13px;color:var(--text-muted);padding-top:4px;">{p.num}</span>
            <div>
              <h2 style="font-family:var(--font-serif);font-size:20px;color:var(--text-main);margin-bottom:4px;font-weight:400;">{p.name}</h2>
              <div style="font-size:11px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:4px;">{p.en}</div>
              <div style="font-size:12px;color:var(--text-muted);margin-bottom:14px;">主持单位：{p.center} &nbsp;·&nbsp; 启动：{p.start}</div>
              <p style="font-size:14.5px;color:var(--text-secondary);line-height:1.7;margin-bottom:12px;">{p.desc}</p>
              <a href={p.href} style="font-size:13px;color:var(--accent-steel);">查看项目详情（英文）→</a>
            </div>
            <div style="text-align:right;">
              <span class={`tag ${p.status === '进行中' || p.status === '待上线' ? 'tag-active' : 'tag-steel'}`}>{p.status}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-compact" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
    <div class="container">
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/zh-cn/research-centers" class="btn btn-primary">研究中心</a>
        <a href="/projects/current"        class="btn btn-secondary">当前项目（英文）</a>
        <a href="/zh-cn/collaboration"     class="btn btn-secondary">提交合作方案</a>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 768px) {
  div[style*="grid-template-columns:56px 1fr 160px"] { display: block !important; }
}
</style>
