---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="研究中心" description="全景研究院现有及规划中的研究中心。" lang="zh-cn">
  <PageHero title="研究中心" description="全景研究院的研究中心是各研究领域的核心学术单元，负责管理研究项目、出版物及学术活动。" breadcrumbs={[{ label: "研究" }]} homeLabel="首页" homeHref="/zh-cn" />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div class="section-label" style="margin-bottom:32px;">现有研究中心</div>
      <div style="display:flex;flex-direction:column;gap:1px;background:var(--border-light);border:1px solid var(--border-light);">
        {[
          { num:"01", name:"学术出版研究中心", en:"Center for Scholarly Publishing Studies", areas:["开放获取","同行评审","出版伦理","编辑标准"], status:"进行中", href:"/research-centers/scholarly-publishing-studies", desc:"研究开放获取模式、同行评审制度、出版伦理、编辑标准及学术传播体系的演变与发展。" },
          { num:"02", name:"学术索引与评价研究中心", en:"Center for Scholarly Indexing and Evaluation", areas:["期刊索引","引文指标","质量框架","数据库透明度"], status:"进行中", href:"/research-centers/scholarly-indexing-evaluation", desc:"研究期刊索引体系、引文指标体系、期刊质量框架及开放学术评价基础设施建设。" },
          { num:"03", name:"政策与社会研究中心", en:"Center for Policy and Social Research", areas:["高等教育政策","科学治理","社会治理","数字治理"], status:"进行中", href:"/research-centers/policy-social-research", desc:"研究高等教育政策、科技创新治理、社会治理及数字治理的政策维度。" },
          { num:"04", name:"人工智能与未来社会研究中心", en:"Center for AI and Future Society", areas:["AI治理","AI伦理","人机交互","数字未来"], status:"即将开展", href:"/research-centers/ai-future-society", desc:"研究人工智能治理、AI伦理、人机交互及AI对学术传播与知识生产影响。" },
        ].map((c) => (
          <div style="background:var(--bg-white);padding:32px 40px;display:grid;grid-template-columns:56px 1fr auto;gap:24px;align-items:start;">
            <span style="font-family:var(--font-mono);font-size:13px;color:var(--text-muted);padding-top:4px;">{c.num}</span>
            <div>
              <h2 style="font-family:var(--font-serif);font-size:20px;color:var(--text-main);margin-bottom:4px;font-weight:400;">{c.name}</h2>
              <div style="font-size:11px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:12px;">{c.en}</div>
              <p style="font-size:14.5px;color:var(--text-secondary);line-height:1.7;margin-bottom:14px;">{c.desc}</p>
              <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px;">
                {c.areas.map((a) => <span class="tag">{a}</span>)}
              </div>
              <a href={c.href} style="font-size:13px;color:var(--accent-steel);">查看中心详情（英文）→</a>
            </div>
            <span class={`tag ${c.status === '进行中' ? 'tag-active' : 'tag-steel'}`}>{c.status}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
    <div class="container">
      <div class="section-label" style="margin-bottom:32px;">规划中研究中心</div>
      <div style="display:flex;flex-direction:column;gap:1px;background:var(--border-light);border:1px solid var(--border-light);opacity:0.65;">
        {[
          { num:"05", name:"教育与学习研究中心", areas:["教育政策","高等教育","学习科学"] },
          { num:"06", name:"艺术、文化与具身研究中心", areas:["音乐","舞蹈","文化研究","创意实践"] },
        ].map((c) => (
          <div style="background:var(--bg-white);padding:24px 40px;display:flex;gap:24px;align-items:center;">
            <span style="font-family:var(--font-mono);font-size:13px;color:var(--text-muted);">{c.num}</span>
            <div style="flex:1;">
              <div style="font-size:16px;color:var(--text-main);margin-bottom:8px;">{c.name}</div>
              <div style="display:flex;flex-wrap:wrap;gap:6px;">{c.areas.map((a) => <span class="tag">{a}</span>)}</div>
            </div>
            <span class="tag">规划中</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-compact" style="background:var(--bg-white);border-top:1px solid var(--border-light);">
    <div class="container">
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/zh-cn/research-areas" class="btn btn-primary">研究领域</a>
        <a href="/zh-cn/projects"       class="btn btn-secondary">研究项目</a>
        <a href="/zh-cn/collaboration"  class="btn btn-secondary">参与合作</a>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 768px) {
  div[style*="grid-template-columns:56px 1fr auto"] { display: block !important; }
}
</style>
