---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="资源" description="全景研究院的模板、指南、标识资产及研究资源下载。" lang="zh-cn">
  <PageHero title="资源" description="全景研究院为合作学者、研究人员及合作伙伴机构提供的模板、指南及机构资源。" breadcrumbs={[{ label: "资源" }]} homeLabel="首页" homeHref="/zh-cn" />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div class="section-label">资源分类</div>
      <div style="display:flex;flex-direction:column;gap:0;margin-top:8px;">

        <div style="padding:32px 0;border-bottom:1px solid var(--border-light);">
          <div style="font-size:18px;font-weight:600;color:var(--text-main);margin-bottom:16px;">研究模板</div>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border-light);border:1px solid var(--border-light);">
            {[
              { name:"研究报告模板",    href:"/resources/report-template",             desc:"用于研究院正式研究报告的标准化写作模板，包含标题页、摘要、目录、方法论、研究发现、结论及参考文献各部分。" },
              { name:"工作论文模板",    href:"/resources/working-paper-template",       desc:"用于提交工作论文的写作模板，包含标准封面格式、脚注规范及参考文献格式要求。" },
              { name:"政策简报模板",    href:"/resources/policy-brief-template",       desc:"政策简报写作模板，包含执行摘要、背景分析、政策建议及参考资料各部分，适合非学术读者。" },
              { name:"研究提案模板",   href:"/resources/research-proposal-template",   desc:"向研究院提交新研究项目或合作申请时使用的标准提案格式，包含研究问题、方法论、时间安排及预期成果各部分。" },
            ].map((item) => (
              <a href={item.href} class="card" style="border-radius:0;border:none;display:block;">
                <div style="font-size:15px;font-weight:600;color:var(--text-main);margin-bottom:8px;">{item.name}</div>
                <p style="font-size:13.5px;color:var(--text-secondary);line-height:1.6;">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div style="padding:32px 0;border-bottom:1px solid var(--border-light);">
          <div style="font-size:18px;font-weight:600;color:var(--text-main);margin-bottom:16px;">机构文件</div>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border-light);border:1px solid var(--border-light);">
            {[
              { name:"研究院章程（PDF）", href:"/resources/charter-pdf",         desc:"研究院官方章程PDF版本，包含全部二十条款，适用于正式引用与档案存储。" },
              { name:"标识使用指南",     href:"/resources/logo-usage-guidelines", desc:"全景研究院官方标识的使用规范，包含允许使用的场景、色彩规范、最小尺寸要求及禁止事项。" },
              { name:"全部模板",         href:"/resources/templates",             desc:"研究院全部可用模板的汇总页面，包括研究报告、工作论文、政策简报及研究提案模板。" },
            ].map((item) => (
              <a href={item.href} class="card" style="border-radius:0;border:none;display:block;">
                <div style="font-size:15px;font-weight:600;color:var(--text-main);margin-bottom:8px;">{item.name}</div>
                <p style="font-size:13.5px;color:var(--text-secondary);line-height:1.6;">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div style="padding:32px 0;">
          <div style="font-size:18px;font-weight:600;color:var(--text-main);margin-bottom:16px;">出版引用</div>
          <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--border-light);border:1px solid var(--border-light);">
            {[
              { name:"引用格式指南", href:"/publications/citation",      desc:"引用研究院出版物的完整格式指南，包含APA、MLA、芝加哥格式，以及DOI引用规范。" },
              { name:"开放获取政策", href:"/governance/publication-report-policy", desc:"研究院出版物的开放获取政策，包含知识共享许可协议条款、DOI注册及档案存储要求。" },
            ].map((item) => (
              <a href={item.href} class="card" style="border-radius:0;border:none;display:block;">
                <div style="font-size:15px;font-weight:600;color:var(--text-main);margin-bottom:8px;">{item.name}</div>
                <p style="font-size:13.5px;color:var(--text-secondary);line-height:1.6;">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="section-compact" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
    <div class="container">
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/resources/templates"            class="btn btn-primary">全部模板</a>
        <a href="/resources/logo-usage-guidelines" class="btn btn-secondary">标识使用指南</a>
        <a href="/zh-cn/contact"                   class="btn btn-secondary">联系我们</a>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 768px) {
  div[style*="grid-template-columns:repeat(3,1fr)"],
  div[style*="grid-template-columns:repeat(2,1fr)"] { display: block !important; }
}
</style>
