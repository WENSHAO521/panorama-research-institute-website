---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const articles = [
  { num:"1",  title:"名稱" },
  { num:"2",  title:"機構性質" },
  { num:"3",  title:"附屬關係" },
  { num:"4",  title:"使命" },
  { num:"5",  title:"活動範圍" },
  { num:"6",  title:"研究領域" },
  { num:"7",  title:"組織架構" },
  { num:"8",  title:"治理" },
  { num:"9",  title:"研究中心" },
  { num:"10", title:"研究項目" },
  { num:"11", title:"出版物" },
  { num:"12", title:"學術活動" },
  { num:"13", title:"學者與研究員" },
  { num:"14", title:"合作" },
  { num:"15", title:"研究倫理" },
  { num:"16", title:"利益衝突" },
  { num:"17", title:"智慧財產權" },
  { num:"18", title:"名稱與標誌的使用" },
  { num:"19", title:"財務與行政" },
  { num:"20", title:"修訂與解釋" },
];
---

<BaseLayout title="研究院章程" description="全景研究院創始章程，確立研究院的治理框架、使命與營運規則。" lang="zh-tw">
  <PageHero
    title="研究院章程"
    description="全景研究院創始章程，確立研究院的機構性質、治理框架、研究使命及營運程序。"
    breadcrumbs={[{ label: "治理" }, { label: "研究院章程" }]}
    tag="治理文件"
    homeLabel="首頁" homeHref="/zh-tw"
  >
    <div style="margin-top:28px;display:flex;gap:12px;flex-wrap:wrap;">
      <a href="/resources/charter-pdf" class="btn btn-primary">下載PDF版</a>
      <a href="/governance/rules"       class="btn btn-secondary">治理規則</a>
    </div>
  </PageHero>

  <div style="background:var(--bg-main);padding:72px 0 96px;">
    <div class="container">
      <div style="display:grid;grid-template-columns:260px 1fr;gap:64px;align-items:start;">

        <div style="position:sticky;top:calc(var(--nav-height) + 24px);">
          <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-muted);margin-bottom:20px;">目錄</div>
          {articles.map((a) => (
            <a href={`#article-${a.num}`} style="display:flex;justify-content:space-between;padding:8px 0;font-size:13px;color:var(--text-secondary);border-bottom:1px solid var(--border-light);transition:color 0.15s;">
              <span>第{a.num}條 &nbsp;{a.title}</span>
            </a>
          ))}
        </div>

        <div>
          <div style="background:var(--bg-white);border:1px solid var(--border-light);padding:56px;margin-bottom:32px;">

            <div style="text-align:center;margin-bottom:48px;padding-bottom:40px;border-bottom:1px solid var(--border-light);">
              <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--text-muted);margin-bottom:16px;">治理文件</div>
              <h1 style="font-family:var(--font-serif);font-size:30px;color:var(--text-main);margin-bottom:12px;letter-spacing:-0.01em;">全景研究院章程</h1>
              <p style="font-size:13px;color:var(--text-muted);font-family:var(--font-mono);">Panorama Research Institute &mdash; 2026年生效</p>
            </div>

            <div id="article-1" style="margin-bottom:48px;">
              <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:12px;text-transform:uppercase;">第一條</div>
              <h2 style="font-family:var(--font-serif);font-size:22px;color:var(--text-main);margin-bottom:16px;font-weight:400;">名稱</h2>
              <p style="font-size:15.5px;line-height:1.85;color:var(--text-secondary);margin-bottom:12px;">本機構的全稱為<strong style="color:var(--text-main);">全景研究院</strong>（Panorama Research Institute），縮寫為<strong style="color:var(--text-main);">PRI</strong>。</p>
              <p style="font-size:15.5px;line-height:1.85;color:var(--text-secondary);">研究院在正式文件、出版物及對外通訊中，可使用「全景研究院」、「Panorama Research Institute」、「PRI」或「本院」等稱謂。除上述形式外，其他縮寫形式不得在正式場合使用。</p>
            </div>

            <div id="article-2" style="margin-bottom:48px;padding-top:40px;border-top:1px solid var(--border-light);">
              <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:12px;text-transform:uppercase;">第二條</div>
              <h2 style="font-family:var(--font-serif);font-size:22px;color:var(--text-main);margin-bottom:16px;font-weight:400;">機構性質</h2>
              <div class="statement-box" style="margin-bottom:20px;">
                <p style="font-size:15.5px;line-height:1.8;color:var(--text-secondary);">全景研究院不具備獨立法人資格，依託全景學術集團的治理體系與行政管理框架運作。</p>
              </div>
              <p style="font-size:15.5px;line-height:1.85;color:var(--text-secondary);margin-bottom:12px;">研究院作為全景學術集團的內部學術部門，在研究工作、出版決策、編輯判斷及學術職能方面保持獨立性，同時服從全景學術集團的整體治理框架與行政管理權威。</p>
              <p style="font-size:15.5px;line-height:1.85;color:var(--text-secondary);">所有正式法律文件、合約及具有約束力的協議均由全景學術集團代表研究院簽署執行。研究院不持有獨立金融帳戶、不具備法律註冊資格，在任何司法管轄區均不具備獨立法律人格。</p>
            </div>

            <div id="article-3" style="margin-bottom:48px;padding-top:40px;border-top:1px solid var(--border-light);">
              <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:12px;text-transform:uppercase;">第三條</div>
              <h2 style="font-family:var(--font-serif);font-size:22px;color:var(--text-main);margin-bottom:16px;font-weight:400;">附屬關係</h2>
              <p style="font-size:15.5px;line-height:1.85;color:var(--text-secondary);margin-bottom:12px;">全景研究院是全景學術集團內部的研究與學術發展部門。在所有正式通訊、出版物、機構介紹及正式協議中，研究院應被描述為「全景學術集團的內部研究與學術發展部門」。</p>
              <p style="font-size:15.5px;line-height:1.85;color:var(--text-secondary);">研究院可以全景研究院的名義簽署學術合作安排、諒解備忘錄及合作協議，但此類安排的正式簽署由全景學術集團負責執行。</p>
            </div>

            <div id="article-4" style="margin-bottom:48px;padding-top:40px;border-top:1px solid var(--border-light);">
              <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:12px;text-transform:uppercase;">第四條</div>
              <h2 style="font-family:var(--font-serif);font-size:22px;color:var(--text-main);margin-bottom:16px;font-weight:400;">使命</h2>
              <p style="font-size:15.5px;line-height:1.85;color:var(--text-secondary);margin-bottom:12px;">全景研究院的使命是：通過嚴謹、獨立、跨學科的研究推動學術知識進步；支持全球學術傳播基礎設施的發展；促進學術出版與科研實踐中的開放性、透明度與誠信精神。</p>
              <p style="font-size:15.5px;line-height:1.85;color:var(--text-secondary);">在踐行使命的過程中，研究院堅守學術品質、研究倫理與機構治理的最高標準，支持各階段學者的成長，促進跨學科與跨機構合作，並確保研究成果面向公眾開放，以紮實的學術實踐為基礎。</p>
            </div>

            <div id="article-5" style="margin-bottom:48px;padding-top:40px;border-top:1px solid var(--border-light);">
              <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:12px;text-transform:uppercase;">第五條</div>
              <h2 style="font-family:var(--font-serif);font-size:22px;color:var(--text-main);margin-bottom:16px;font-weight:400;">活動範圍</h2>
              <p style="font-size:15.5px;line-height:1.85;color:var(--text-secondary);margin-bottom:16px;">研究院開展並支持以下類別的活動：</p>
              {[
                "在指定研究領域開展跨學科研究，通過研究中心和研究項目推進",
                "在研究院指定研究領域內設立、發展和管理研究中心",
                "發起、管理和支持隸屬於研究院研究中心的研究項目",
                "出版研究報告、工作論文、政策簡報、主編學術文集、指南及年度報告",
                "組織和聯合組織學術會議、研討會、工作坊及培訓項目",
                "管理學者與研究員項目，包括研究員、副研究員、訪問學者及研究助理",
                "與高校、研究機構、出版社及學術組織開展機構合作與研究夥伴關係",
                "開發開放學術基礎設施，包括資料庫、評價框架及後設資料體系",
                "開展與研究院研究領域相關的政策分析與諮詢活動",
                "為研究人員、期刊編輯及學術實踐者提供能力建設服務",
              ].map((item) => (
                <div style="display:flex;gap:12px;padding:10px 0;border-bottom:1px solid var(--bg-soft);">
                  <span style="color:var(--text-muted);flex-shrink:0;">&#8212;</span>
                  <span style="font-size:15px;color:var(--text-secondary);line-height:1.7;">{item}</span>
                </div>
              ))}
            </div>

            <div id="article-6" style="margin-bottom:48px;padding-top:40px;border-top:1px solid var(--border-light);">
              <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:12px;text-transform:uppercase;">第六條</div>
              <h2 style="font-family:var(--font-serif);font-size:22px;color:var(--text-main);margin-bottom:16px;font-weight:400;">研究領域</h2>
              <p style="font-size:15.5px;line-height:1.85;color:var(--text-secondary);margin-bottom:20px;">研究院設定以下研究領域，研究中心、研究項目、出版物及學術活動均在此框架內開展。研究領域的擴展或調整須依據第二十條的規定，通過正式章程修訂程序進行。</p>
              {[
                { num:"I",   name:"學術出版研究",       desc:"研究開放取用模式、同儕評審制度、出版倫理、編輯標準、學術誠信及學術出版的結構與實踐。" },
                { num:"II",  name:"學術索引與評價研究", desc:"研究期刊索引體系、引文指標、期刊品質框架、資料庫治理與透明度，以及開放學術評價基礎設施。" },
                { num:"III", name:"政策與社會研究",     desc:"研究高等教育政策、科技與創新治理、社會治理、數位治理，以及學術傳播的政策維度。" },
                { num:"IV",  name:"人工智慧與未來社會", desc:"研究人工智慧治理、AI倫理、人機互動、AI對學術傳播與知識生產的影響，以及數位未來議題。" },
                { num:"V",   name:"教育與學習研究",     desc:"研究教育體制、教學法、學習科學、教育政策，以及技術在學習環境中的作用。" },
                { num:"VI",  name:"藝術、文化與具身研究", desc:"研究藝術實踐、文化研究、具身認知、創意探索，以及藝術與人文學科同學術與社會研究的交叉領域。" },
              ].map((a) => (
                <div style="display:grid;grid-template-columns:28px 1fr;gap:16px;padding:14px 0;border-bottom:1px solid var(--bg-soft);align-items:start;">
                  <span style="font-family:var(--font-mono);font-size:12px;color:var(--text-muted);padding-top:2px;">{a.num}</span>
                  <div>
                    <div style="font-size:15px;font-weight:600;color:var(--text-main);margin-bottom:4px;">{a.name}</div>
                    <div style="font-size:14px;line-height:1.65;color:var(--text-secondary);">{a.desc}</div>
                  </div>
                </div>
              ))}
            </div>

            <div id="article-7" style="margin-bottom:48px;padding-top:40px;border-top:1px solid var(--border-light);">
              <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:12px;text-transform:uppercase;">第七條</div>
              <h2 style="font-family:var(--font-serif);font-size:22px;color:var(--text-main);margin-bottom:16px;font-weight:400;">組織架構</h2>
              <p style="font-size:15.5px;line-height:1.85;color:var(--text-secondary);margin-bottom:20px;">研究院設置以下組織單元，各單元負責特定領域的機構職能，並向院長負責。</p>
              {[
                { unit:"院務辦公室",     desc:"負責整體行政管理、治理合規、內部協調、對外通訊及官方檔案的維護，由院長主持工作。" },
                { unit:"研究中心",       desc:"研究院的核心學術單元。各中心設有主任，並配有明確的研究職責及研究項目、出版物和學術活動計劃。現有研究中心詳見第九條。" },
                { unit:"出版部門",       desc:"負責研究院全部出版物（包括研究報告、工作論文、政策簡報、主編文集及年度報告）的編輯管理、製作及開放取用發布。" },
                { unit:"學術活動部門",   desc:"負責研究院學術會議、研討會、工作坊、培訓項目及徵稿活動的策劃、協調與執行。" },
                { unit:"學者與研究員項目", desc:"負責研究員、副研究員、訪問學者及研究助理的招募、入職與支持工作，並維護研究院學術共同體。" },
                { unit:"合作辦公室",     desc:"負責管理研究院的外部夥伴關係、機構合作協議、研究項目方案、學術文集方案及學術活動聯合組織事宜。" },
              ].map((item) => (
                <div style="padding:14px 0;border-bottom:1px solid var(--bg-soft);">
                  <div style="font-size:15px;font-weight:600;color:var(--text-main);margin-bottom:5px;">{item.unit}</div>
                  <div style="font-size:14.5px;line-height:1.7;color:var(--text-secondary);">{item.desc}</div>
                </div>
              ))}
            </div>

            <div id="article-8" style="margin-bottom:48px;padding-top:40px;border-top:1px solid var(--border-light);">
              <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:12px;text-transform:uppercase;">第八條</div>
              <h2 style="font-family:var(--font-serif);font-size:22px;color:var(--text-main);margin-bottom:16px;font-weight:400;">治理</h2>
              <p style="font-size:15.5px;line-height:1.85;color:var(--text-secondary);margin-bottom:20px;">研究院依據以下治理架構運作，所有治理活動須符合本章程及全景學術集團整體治理框架的要求。</p>
              {[
                { role:"院長",         desc:"院長是研究院的最高負責人，負責研究院的整體學術方向、治理合規、外部代表及機構發展。院長由全景學術集團任命。" },
                { role:"研究中心主任", desc:"各研究中心設主任一名，負責中心的研究項目、研究員管理及學術活動。中心主任由院長任命。" },
                { role:"顧問委員會",   desc:"顧問委員會是獨立諮詢機構，由傑出學者與業界人士組成，就研究優先領域、學術標準及機構發展提供建議，不具備行政權力。" },
                { role:"全景學術集團", desc:"作為母機構，全景學術集團對研究院擁有最終治理權威。其負責批准章程及重大修訂，管理研究院財務，並代表研究院簽署正式法律文件。" },
              ].map((item) => (
                <div style="padding:14px 0;border-bottom:1px solid var(--bg-soft);">
                  <div style="font-size:15px;font-weight:600;color:var(--text-main);margin-bottom:5px;">{item.role}</div>
                  <div style="font-size:14.5px;line-height:1.7;color:var(--text-secondary);">{item.desc}</div>
                </div>
              ))}
            </div>

            {[
              { num:"9",  title:"研究中心", body:"研究中心是研究院的核心學術單元。每個中心須在一個或多個指定研究領域內開展工作，負責管理研究項目、開展出版、組織活動及構建學術網絡。各中心設主任，配備隸屬研究員及其他學者。院長經全景學術集團批准，可設立新的研究中心，前提是擬設中心須落於指定研究領域範圍之內。研究中心的設立、變更或撤銷無需修訂本章程，除非涉及第六條的調整。當前已設立研究中心：（01）學術出版研究中心；（02）學術索引與評價研究中心；（03）政策與社會研究中心；（04）人工智慧與未來社會研究中心（即將開展）。" },
              { num:"10", title:"研究項目", body:"研究項目是經研究院認可、隸屬於一個或多個研究中心的正式研究計劃。每個項目須有明確的研究範圍、研究問題、方法論、時間表及預期成果。項目須通過正式立項申請，經相關研究中心主任審核後報院長批准。項目可由隸屬研究員、訪問學者或外部研究人員主持，前提是其工作須符合研究院的品質與倫理標準。所有以研究院名義開展的研究工作，均須與本章程規定的價值觀、政策及倫理標準保持一致。研究院在其官方網站上公開記錄所有進行中及已完成的研究項目。" },
              { num:"11", title:"出版物", body:"研究院出版以下類別的出版物，所有出版物在發布前須經編輯審核、品質控制及出版倫理合規審查：（一）研究報告：呈現原創研究成果的全長報告，經內部評審與外部同儕評審；（二）工作論文：呈現初步研究發現或理論框架的簡短學術文章，經內部編輯評審；（三）政策簡報：向政策受眾呈現研究發現與建議的簡潔文件，經內部編輯評審；（四）主編學術文集：多位學者圍繞特定主題合作撰寫的文集，與合作學術出版社聯合出版；（五）年度報告：記錄研究院每年研究活動、出版物、活動、研究員項目及治理情況的年度機構報告；（六）指南與標準：基於研究成果開發、供期刊和機構參考的實用標準文件。所有出版物均以開放取用形式發布，並向Crossref註冊數位物件識別碼（DOI）。" },
              { num:"12", title:"學術活動", body:"研究院組織和聯合組織各類學術活動，以推動指定研究領域內的學術交流，支持學術共同體建設。活動形式包括國際學術會議、學術研討會、研究工作坊、培訓項目及其他相關學術聚會。聯合舉辦的活動須經院長批准，並須符合研究院的學術標準、倫理要求及品牌規範。所有聯合活動均不得損害研究院的學術獨立性或學術共同體的誠信。學術活動部門負責徵稿管理、活動後勤協調、發言人與參與者聯絡，以及會議記錄與論文集的製作（如適用）。" },
              { num:"13", title:"學者與研究員", body:"研究院通過以下正式類別維繫隸屬學者共同體。每類別均有明確的職責與權利。隸屬關係不構成與全景研究院或全景學術集團的僱用關係，除非另有單獨約定。（一）研究員：通常持有博士學位或同等資歷的成熟研究人員，正式承諾通過原創出版、參與活動及融入學術共同體為研究院研究項目作出貢獻；任期一至三年，可續期；（二）副研究員：為研究院研究項目和活動作出貢獻的早期職業研究人員或博士研究生，通常任期一年，可續期，表現優秀者可晉升為研究員；（三）訪問學者：在特定時期（通常三至十二個月）與研究院學者開展合作研究的成熟研究人員，可駐場或遠程；（四）研究助理：在研究員或中心主任監督下，以項目為基礎參與研究工作的研究生或早期職業研究人員。所有隸屬學者須遵守研究院的研究倫理政策、利益衝突政策及其他治理文件。" },
              { num:"14", title:"合作", body:"研究院與高校、研究機構、出版社、學術協會及其他組織開展學術合作。合作活動須與研究院的使命、研究領域及價值觀相符，且不得損害研究院的學術獨立性或學者的誠信。本章程確認以下合作形式：（一）機構合作協議及諒解備忘錄；（二）聯合研究項目與合作出版；（三）聯合主編學術文集及聯合組織期刊特刊；（四）聯合組織學術會議、研討會、工作坊及培訓項目；（五）學者與訪問研究員交流項目；（六）聯合能力建設與培訓活動。鑒於研究院不具備獨立法人資格，正式合作協議由全景學術集團代表研究院簽署執行。合作辦公室負責處理所有合作諮詢、方案及持續夥伴關係管理事宜。" },
              { num:"15", title:"研究倫理", body:"研究院致力於堅守最高研究倫理標準。所有以研究院名義開展的研究工作須符合適用的倫理原則，包括尊重人、有益性、無害性、公正性與透明性。以下原則構成研究院研究倫理的最低標準，並在研究院研究倫理政策（作為本章程附屬治理文件採納）中詳細闡述：（一）涉及人類受試者的研究須符合適用的倫理審查要求，並在必要時獲得知情同意；（二）研究資料須依據研究院資料與文件政策進行收集、管理、保存和共享；（三）研究發現須誠實、準確地報告，不得選擇性遺漏重要證據；（四）研究方法和局限性須在所有出版物中透明披露；（五）捏造、篡改及抄襲行為被嚴格禁止，構成立即撤銷隸屬關係及撤回受影響出版物的理由；（六）作者須如實反映其對出版作品的貢獻，不得將未作出實質性貢獻的人列為作者。疑似違反研究倫理標準的行為須向院長報告。院長將對舉報的違規行為進行調查，並可採取補救措施，包括撤回出版物、撤銷隸屬關係或轉交當事人所在機構處理。" },
              { num:"16", title:"利益衝突", body:"所有與研究院有隸屬關係的人員，包括研究員、副研究員、訪問學者、研究助理、研究中心主任及院長，須披露任何實際存在的、潛在的或可能被視為存在的利益衝突，該衝突可能影響或被認為影響其以研究院名義開展的研究工作、出版物、編輯判斷或其他職業活動的誠信性。當一個人的經濟利益、機構關係、個人關係或其他利益可能影響或被認為影響其職業判斷時，即存在利益衝突。披露的門檻較低：如有疑問，須進行披露。利益衝突須在所有相關研究院出版物中予以披露，並須在開始隸屬關係時及每當出現新的衝突時向院長報告。未披露重大利益衝突可能構成第十五條規定的研究倫理違規。利益衝突的認定、披露及管理的完整規定載於研究院利益衝突政策（作為本章程附屬治理文件採納）。" },
              { num:"17", title:"智慧財產權", body:"在研究院主持下產生的研究出版物的著作權由具名作者保留。作者授予全景研究院非獨占、永久、不可撤銷、全球範圍內的免版稅許可，允許研究院以任何形式（包括數位形式）對其作品進行出版、複製、傳播、存檔及提供取用。所有研究院出版物均以知識共享署名4.0國際授權條款（CC BY 4.0）發布，除非在出版前以書面形式與作者另行商定採用其他開放授權條款。CC BY 4.0授權條款允許任何人以任何目的分享、改作和使用該作品，前提是須向作者和研究院給予適當的署名。研究院隸屬研究項目所產生的研究資料，應在符合適用隱私、保密及法律要求的範圍內，最大限度地向公眾開放。所有研究出版物須包含資料取用聲明。研究院的名稱、標誌及視覺識別系統為全景學術集團的財產，其使用受第十八條及據此採納的附屬治理文件約束。" },
              { num:"18", title:"名稱與標誌的使用", body:"全景研究院的名稱及標誌只能由經授權的人員和機構使用。授權由院長授予，在正式機構使用的情況下由全景學術集團授予。獲授權的使用情形包括：隸屬學者在研究院批准的研究與出版活動中的使用；合作機構在經研究院正式批准的文件中引用與研究院的合作；媒體關於研究院及其活動的如實報導；經研究院活動部門正式批准為聯合組織活動的活動材料中的使用。明確禁止的使用情形包括：暗示研究院對任何未經授權的立場、產品或機構的認可；在研究院未正式批准的出版物的標題或封面上使用研究院名稱；對研究院標誌進行改動、扭曲或與其他視覺元素組合；在隸屬關係終止後繼續使用研究院名稱或標誌。詳細使用要求（包括標誌規格）載於研究院名稱與標誌使用政策（作為本章程附屬治理文件採納）。" },
              { num:"19", title:"財務與行政", body:"鑒於研究院不具備獨立法人資格或獨立金融帳戶，研究院所有財務事務均由全景學術集團管理。研究院不以自身名義簽訂金融合約、持有資金或承擔負債。研究院研究、出版、活動及學者項目的營運預算由全景學術集團與院長協商後劃撥。院長負責在劃撥預算範圍內管理支出，並按要求向全景學術集團提供財務報告。隸屬學者所獲的獎學金、講課費或報酬由全景學術集團管理。此類款項的發放與金額由個案決定，並非僅憑隸屬關係即可保證。研究院在所有出版物、官方網站及正式通訊中公開披露其機構附屬關係和營運狀況。研究院不以自身名義接受外部研究經費。涉及第三方經費或捐助的經費安排由全景學術集團負責，並在相關出版物中予以披露。" },
              { num:"20", title:"修訂與解釋", body:"本章程可由院長在獲得全景學術集團批准的情況下進行修訂。擬議修訂須在採納前至少三十天向所有研究中心主任及顧問委員會傳閱，以聽取意見。在此期間收到的意見須在最終決策前予以考量，但不具有約束力。修訂自採納之日起生效，除非另行規定較晚的生效日期。章程的版本號及生效日期記錄於文件封面。章程的完整版本歷史由院務辦公室保存，可應要求提供。附屬治理文件，包括研究倫理政策、利益衝突政策、出版與報告政策、資料與文件政策、學術獨立政策及名稱與標誌使用政策，可由院長在無需正式修訂章程的情況下予以採納、修訂或替換，前提是不得與本章程的規定相牴觸。院長對本章程各條款的解釋具有最終權威。對任何條款的解釋如存在歧義，應優先選擇與第四條規定的研究院使命最為一致的解釋。本章程與任何附屬治理文件發生衝突時，以本章程為準。" },
            ].map((art) => (
              <div id={`article-${art.num}`} style="margin-bottom:48px;padding-top:40px;border-top:1px solid var(--border-light);">
                <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:12px;text-transform:uppercase;">第{art.num}條</div>
                <h2 style="font-family:var(--font-serif);font-size:22px;color:var(--text-main);margin-bottom:16px;font-weight:400;">{art.title}</h2>
                <p style="font-size:15.5px;line-height:1.85;color:var(--text-secondary);">{art.body}</p>
              </div>
            ))}

          </div>

          <div style="display:flex;gap:12px;flex-wrap:wrap;">
            <a href="/resources/charter-pdf"     class="btn btn-primary">下載章程PDF</a>
            <a href="/governance/rules"           class="btn btn-secondary">治理規則</a>
            <a href="/governance/research-ethics" class="btn btn-secondary">研究倫理</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

