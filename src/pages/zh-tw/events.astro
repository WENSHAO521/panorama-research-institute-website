---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="學術活動" description="全景研究院組織的學術會議、研討會、工作坊及徵稿活動。" lang="zh-tw">
  <PageHero title="學術活動" description="全景研究院通過組織多種形式的學術活動，推動各研究領域內的學術交流與共同體建設。" breadcrumbs={[{ label: "活動" }]} homeLabel="首頁" homeHref="/zh-tw" />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div class="statement-box" style="max-width:720px;margin-bottom:48px;">
        <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-muted);margin-bottom:10px;">活動說明</div>
        <p style="font-size:15.5px;line-height:1.8;color:var(--text-secondary);margin:0;">
          全景研究院成立於2026年，正處於創建奠基階段。研究院的首批學術活動正在策劃中，將在研究中心和研究項目具備充分的研究成果積累後陸續舉辦。
        </p>
      </div>
      <div class="section-label" style="margin-bottom:32px;">活動類型</div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border-light);border:1px solid var(--border-light);">
        {[
          { type:"學術會議",   en:"學術會議",       href:"/events/conferences",       desc:"聚焦研究院核心研究領域的國際學術會議，接受原創研究論文，經同儕審查遴選發言人。" },
          { type:"學術研討會", en:"學術研討會",           href:"/events/seminars",           desc:"小型專題研討會，邀請研究院學者及訪問研究人員就特定研究議題深入交流。" },
          { type:"研究工作坊", en:"研究工作坊",          href:"/events/workshops",          desc:"以實踐為導向的小型學術工作坊，聚焦方法論、研究設計或具體研究議題。" },
          { type:"培訓項目",   en:"培訓項目",  href:"/events/training-programs",  desc:"面向期刊編輯、研究人員及學術實踐者的能力建設培訓項目。" },
          { type:"徵稿啟事",   en:"徵稿啟事",   href:"/events/calls-for-papers",  desc:"面向會議和特刊的學術論文徵集公告，歡迎符合研究領域的原創投稿。" },
          { type:"徵集書稿",   en:"徵集書稿", href:"/events/calls-for-chapters", desc:"面向研究院主編學術文集的書稿徵集公告，歡迎學術界同仁參與投稿。" },
        ].map((item) => (
          <a href={item.href} class="card" style="border-radius:0;border:none;display:block;">
            <div style="font-size:16px;font-weight:600;color:var(--text-main);margin-bottom:4px;">{item.type}</div>
            <div style="font-size:11px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:10px;">{item.en}</div>
            <p style="font-size:14px;color:var(--text-secondary);line-height:1.65;">{item.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-compact" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
    <div class="container">
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/events/calls-for-papers"   class="btn btn-primary">徵稿啟事（英文）</a>
        <a href="/events/calls-for-chapters" class="btn btn-secondary">徵集書稿（英文）</a>
        <a href="/zh-tw/collaboration"        class="btn btn-secondary">活動合作申請</a>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 768px) {
  div[style*="grid-template-columns:repeat(3,1fr)"] { display: block !important; }
}
</style>
