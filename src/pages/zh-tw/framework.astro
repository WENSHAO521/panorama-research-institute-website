---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="研究院框架" description="全景研究院的組織框架、治理體系與發展路線圖。" lang="zh-tw">
  <PageHero title="研究院框架" description="全景研究院的組織框架概述，涵蓋機構治理體系、研究架構、發展路線圖及長期戰略方向。" breadcrumbs={[{ label: "研究院", href: "/zh-tw/about" }, { label: "框架" }]} homeLabel="首頁" homeHref="/zh-tw" />

  <!-- Governance -->
  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div class="section-label">治理框架</div>
      <h2 class="section-title">機構治理體系</h2>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--border-light);border:1px solid var(--border-light);margin-top:8px;">
        {[
          { role:"全景學術集團", desc:"母機構，擁有最終治理權威，負責批准章程、管理財務及簽署正式法律文件。" },
          { role:"研究院院長",   desc:"最高負責人，負責整體學術方向、治理合規、外部代表及機構發展。" },
          { role:"研究中心主任", desc:"各研究中心主任負責中心的研究項目、研究員管理及學術活動。" },
          { role:"顧問委員會",   desc:"獨立諮詢機構，由傑出學者與業界人士組成，就研究優先領域、學術標準及機構發展提供建議。" },
        ].map((item) => (
          <div class="card" style="border-radius:0;border:none;">
            <div style="font-size:16px;font-weight:600;color:var(--text-main);margin-bottom:8px;">{item.role}</div>
            <p style="font-size:14.5px;color:var(--text-secondary);line-height:1.7;">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Core Documents -->
  <section class="section" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
    <div class="container">
      <div class="section-label">核心文件</div>
      <h2 class="section-title">治理文件體系</h2>
      <div style="display:flex;flex-direction:column;gap:0;">
        {[
          { name:"研究院章程",         href:"/zh-tw/charter",                    status:"生效中", desc:"確立研究院機構性質、使命、研究領域、組織架構及治理規則的創始文件。" },
          { name:"治理規則",           href:"/governance/rules",                  status:"生效中", desc:"補充章程的詳細治理程序與操作規範（英文版）。" },
          { name:"研究倫理政策",       href:"/governance/research-ethics",        status:"生效中", desc:"規定研究院全體研究人員必須遵守的研究倫理原則與標準（英文版）。" },
          { name:"利益衝突政策",       href:"/governance/conflict-of-interest",   status:"生效中", desc:"規定利益衝突的認定、披露與管理程序（英文版）。" },
          { name:"學術獨立聲明",       href:"/governance/academic-independence",  status:"生效中", desc:"闡明研究院學術獨立性原則及其與全景學術集團關係的正式聲明（英文版）。" },
          { name:"出版與報告政策",     href:"/governance/publication-report-policy", status:"生效中", desc:"規定研究院出版物的編輯標準、品質控制及開放獲取要求（英文版）。" },
        ].map((doc) => (
          <div style="display:grid;grid-template-columns:1fr 120px auto;gap:24px;padding:18px 0;border-bottom:1px solid var(--border-light);align-items:center;">
            <div>
              <a href={doc.href} style="font-size:15px;font-weight:600;color:var(--text-main);">{doc.name}</a>
              <p style="font-size:13.5px;color:var(--text-secondary);margin-top:4px;line-height:1.5;">{doc.desc}</p>
            </div>
            <span class="tag tag-active" style="justify-self:start;">{doc.status}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Roadmap -->
  <section class="section" style="background:var(--bg-white);border-top:1px solid var(--border-light);">
    <div class="container">
      <div class="section-label">發展路線圖</div>
      <h2 class="section-title">分階段發展規劃</h2>
      <div style="max-width:720px;">
        {[
          { phase:"第一階段", label:"創建與奠基", year:"2026", status:"當前", items:["建立研究院治理框架、章程及核心政策","啟動研究院官方網站及數位形象","設立三個初始研究中心","完成POSI資料庫開發並準備正式上線","啟動第十五個五年規劃研究項目","招募首批研究員與訪問學者","發布首批工作論文","啟動合作申請與研究員招募流程"] },
          { phase:"第二階段", label:"發展與拓展", year:"2027", status:"即將開展", items:["設立人工智慧與未來社會研究中心","將研究員網絡擴展至至少五個國家","啟動正式訪問學者項目","發布研究院首份年度報告","正式上線並營運POSI資料庫","發布首批全長研究報告","組織首屆學術研討會系列","建立顧問委員會","開始正式機構合作洽談"] },
          { phase:"第三階段", label:"擴展與深化", year:"2028+", status:"規劃中", items:["建立國際合作網絡","開展更廣泛的政策諮詢活動","擴大出版項目規模","組織學術會議系列"] },
        ].map((phase) => (
          <div style="display:grid;grid-template-columns:120px 1fr;gap:28px;padding:28px 0;border-bottom:1px solid var(--border-light);">
            <div>
              <div style="font-family:var(--font-mono);font-size:11px;text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:6px;">{phase.phase}</div>
              <div style="font-size:18px;font-weight:600;color:var(--text-main);">{phase.label}</div>
              <div style="font-family:var(--font-mono);font-size:12px;color:var(--text-muted);margin-top:4px;">{phase.year}</div>
              <span class={`tag ${phase.status === '當前' ? 'tag-active' : phase.status === '即將開展' ? 'tag-steel' : ''}`} style="margin-top:8px;display:inline-block;">{phase.status}</span>
            </div>
            <div style="padding-top:4px;">
              {phase.items.map((item) => (
                <div style="display:flex;gap:10px;padding:6px 0;font-size:14.5px;color:var(--text-secondary);">
                  <span style="color:var(--text-muted);flex-shrink:0;">&#8212;</span>{item}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-compact" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
    <div class="container">
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/zh-tw/charter"          class="btn btn-primary">研究院章程</a>
        <a href="/zh-tw/research-centers" class="btn btn-secondary">研究中心</a>
        <a href="/framework/development-roadmap" class="btn btn-secondary">完整路線圖（英文）</a>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 768px) {
  div[style*="grid-template-columns:repeat(2,1fr)"],
  div[style*="grid-template-columns:120px 1fr"],
  div[style*="grid-template-columns:1fr 120px auto"] { display: block !important; }
}
</style>
