---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="全景研究院" description="全景研究院是全景學術集團旗下的獨立學術研究機構，致力於推動學術出版、學術索引、政策研究及人工智能與社會研究領域的前沿研究。" lang="zh-tw">

  <!-- Hero -->
  <section style="background:var(--bg-dark);padding:100px 0 80px;">
    <div class="container">
      <div style="max-width:720px;">
        <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.16em;text-transform:uppercase;color:rgba(255,255,255,0.4);margin-bottom:28px;">
          全景研究院 &nbsp;·&nbsp; Panorama Research Institute
        </div>
        <h1 style="font-family:var(--font-serif);font-size:clamp(36px,5vw,58px);color:#fff;line-height:1.12;font-weight:400;margin-bottom:28px;">
          嚴謹研究，<br/>推動學術進步
        </h1>
        <p style="font-size:18px;color:rgba(255,255,255,0.65);line-height:1.75;max-width:580px;margin-bottom:40px;">
          全景研究院是全景學術集團旗下的獨立學術研究機構，成立於2026年，致力於推動學術出版、學術索引、政策研究及人工智慧與未來社會研究領域的前沿學術研究。
        </p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;">
          <a href="/zh-tw/about"            class="btn btn-primary">了解研究院</a>
          <a href="/zh-tw/research-centers" class="btn btn-secondary" style="color:#fff;border-color:rgba(255,255,255,0.3);">研究中心</a>
          <a href="/zh-tw/charter"          class="btn btn-secondary" style="color:#fff;border-color:rgba(255,255,255,0.3);">研究院章程</a>
        </div>
      </div>
    </div>
  </section>

  <!-- About snapshot -->
  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start;">
        <div>
          <div class="section-label">關於研究院</div>
          <h2 style="font-family:var(--font-serif);font-size:32px;color:var(--text-main);font-weight:400;margin-bottom:20px;line-height:1.3;">
            嚴謹、獨立、開放
          </h2>
          <p style="font-size:16px;color:var(--text-secondary);line-height:1.8;margin-bottom:16px;">
            全景研究院作為全景學術集團旗下的正式研究機構，在學術獨立性原則下開展研究活動。研究院不承擔任何大學附屬或政府資助義務，學術議程完全由研究人員根據學術需求自主制定。
          </p>
          <p style="font-size:16px;color:var(--text-secondary);line-height:1.8;margin-bottom:24px;">
            研究院的所有研究成果均以開放獲取形式向全球學術界免費提供，並依照知識共享4.0國際許可協議（CC BY 4.0）授權。
          </p>
          <a href="/zh-tw/about" class="btn btn-secondary">了解更多</a>
        </div>
        <div style="display:flex;flex-direction:column;gap:0;">
          {[
            ["機構性質", "全景學術集團旗下獨立研究機構"],
            ["成立年份", "2026年"],
            ["研究中心", "四個（三個活躍，一個籌建）"],
            ["現行項目", "五個"],
            ["出版政策", "全部開放獲取，CC BY 4.0"],
            ["研究員",   "公開招募中"],
          ].map(([k, v]) => (
            <div style="display:grid;grid-template-columns:120px 1fr;gap:16px;padding:14px 0;border-bottom:1px solid var(--border-light);">
              <span style="font-family:var(--font-mono);font-size:11.5px;color:var(--text-muted);">{k}</span>
              <span style="font-size:14px;color:var(--text-main);">{v}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Research centers -->
  <section class="section" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
    <div class="container">
      <div class="section-label">研究中心</div>
      <h2 class="section-title">四大研究中心</h2>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--border-light);border:1px solid var(--border-light);margin-top:8px;">
        {[
          { name:"學術出版研究中心", en:"學術出版研究中心", status:"活躍", desc:"研究學術出版生態系統，涵蓋同儕審查、開放獲取、出版倫理及出版商行為研究。" },
          { name:"學術索引與評價研究中心", en:"學術索引與評價研究中心", status:"活躍", desc:"研究學術期刊索引系統、引用指標、期刊評價標準及開放索引基礎設施建設。" },
          { name:"政策與社會研究中心", en:"政策與社會研究中心", status:"活躍", desc:"研究教育政策、社會治理及青少年數位公民議題，尤其關注中國政策發展趨勢。" },
          { name:"人工智慧與未來社會研究中心", en:"人工智慧與未來社會研究中心", status:"籌建", desc:"研究人工智慧治理、倫理規範及AI對學術傳播與知識生產的影響。" },
        ].map((c) => (
          <div class="card" style="border-radius:0;border:none;">
            <div style="display:flex;align-items:start;justify-content:space-between;margin-bottom:8px;">
              <div style="font-size:16px;font-weight:600;color:var(--text-main);">{c.name}</div>
              <span class={`tag ${c.status === '活躍' ? 'tag-active' : 'tag-steel'}`} style="flex-shrink:0;margin-left:8px;">{c.status}</span>
            </div>
            <div style="font-size:11px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:10px;">{c.en}</div>
            <p style="font-size:14px;color:var(--text-secondary);line-height:1.65;">{c.desc}</p>
          </div>
        ))}
      </div>
      <div style="margin-top:24px;">
        <a href="/zh-tw/research-centers" class="btn btn-secondary">查看全部研究中心</a>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section class="section" style="background:var(--bg-white);border-top:1px solid var(--border-light);">
    <div class="container">
      <div class="section-label">當前項目</div>
      <h2 class="section-title">五個進行中的研究項目</h2>
      <div style="display:flex;flex-direction:column;gap:0;margin-top:8px;">
        {[
          { num:"01", name:"全景開放學術索引項目（POSI）", status:"待上線" },
          { num:"02", name:"第十五個五年規劃研究",         status:"進行中" },
          { num:"03", name:"學術出版標準研究項目",         status:"進行中" },
          { num:"04", name:"青少年數位治理研究",           status:"進行中" },
          { num:"05", name:"人工智慧與未來社會研究",       status:"籌備中" },
        ].map((p) => (
          <div style="display:grid;grid-template-columns:48px 1fr auto;gap:24px;padding:16px 0;border-bottom:1px solid var(--border-light);align-items:center;">
            <span style="font-family:var(--font-mono);font-size:12px;color:var(--text-muted);">{p.num}</span>
            <span style="font-size:15px;color:var(--text-main);">{p.name}</span>
            <span class={`tag ${p.status === '進行中' ? 'tag-active' : 'tag-steel'}`}>{p.status}</span>
          </div>
        ))}
      </div>
      <div style="margin-top:24px;">
        <a href="/zh-tw/projects" class="btn btn-secondary">查看全部項目</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="background:var(--bg-dark);">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr auto;gap:48px;align-items:center;flex-wrap:wrap;">
        <div>
          <h2 style="font-family:var(--font-serif);font-size:30px;color:#fff;font-weight:400;margin-bottom:12px;">加入全景研究院</h2>
          <p style="font-size:16px;color:rgba(255,255,255,0.6);line-height:1.7;margin:0;">研究院歡迎全球各學科領域的學者申請研究員職位，並歡迎機構、出版社與研究人員提出合作申請。</p>
        </div>
        <div style="display:flex;gap:12px;flex-wrap:wrap;justify-content:flex-end;">
          <a href="/zh-tw/people"        class="btn btn-primary">研究員申請</a>
          <a href="/zh-tw/collaboration" class="btn btn-secondary" style="color:#fff;border-color:rgba(255,255,255,0.3);">機構合作</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
<style>
@media (max-width: 768px) {
  div[style*="grid-template-columns:1fr 1fr"],
  div[style*="grid-template-columns:repeat(2,1fr)"],
  div[style*="grid-template-columns:1fr auto"],
  div[style*="grid-template-columns:120px 1fr"],
  div[style*="grid-template-columns:48px 1fr auto"] { display: block !important; }
}
</style>
