---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="人員" description="全景研究院的學者團隊，包括研究員、副研究員、訪問學者及顧問委員會。" lang="zh-tw">
  <PageHero title="人員" description="全景研究院通過研究員項目匯聚來自不同機構、不同學科背景的學者，共同推動研究院各領域的學術發展。" breadcrumbs={[{ label: "人員" }]} homeLabel="首頁" homeHref="/zh-tw" />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div class="section-label">學者類別</div>
      <div style="display:flex;flex-direction:column;gap:0;">
        {[
          { title:"研究員", en:"Research Fellow", href:"/people/research-fellows", desc:"研究員是研究院的核心學術成員，通常持有博士學位或同等資歷，以正式承諾參與研究院的研究項目、學術出版及共同體活動。研究員任期通常為一至三年，可續期。", req:"博士學位或同等資歷 · 原創研究能力 · 參與研究院學術活動的承諾" },
          { title:"副研究員", en:"Associate Research Fellow", href:"/people/associate-research-fellows", desc:"副研究員為早期職業研究人員或博士研究生，通過參與研究項目和學術活動為研究院作出貢獻。任期通常為一年，可續期，表現優秀者可晉升為研究員。", req:"在讀博士生或早期職業研究人員 · 明確的研究興趣與研究院匹配" },
          { title:"訪問學者", en:"Visiting Scholar", href:"/people/visiting-scholars", desc:"訪問學者是在特定時期（通常三至十二個月）與研究院學者開展合作研究的成熟研究人員，可駐場或遠端參與。訪問學者身份不涉及僱用關係。", req:"成熟研究人員 · 明確的訪問研究計劃 · 與研究院研究領域相關" },
          { title:"研究助理", en:"Research Assistant", href:"/people/research-assistants", desc:"研究助理為在讀研究生或早期職業研究人員，在研究員或中心主任監督下，以項目為基礎參與研究工作，承擔資料收集、文獻整理等具體研究任務。", req:"在讀碩士或博士研究生 · 具體項目參與意願" },
          { title:"顧問委員會", en:"Advisory Board", href:"/people/advisory-board", desc:"顧問委員會由傑出學者與業界人士組成，就研究優先領域、學術標準及機構發展提供獨立諮詢意見，不具備行政權力。", req:"傑出學者或業界人士 · 邀請制" },
        ].map((role) => (
          <div style="display:grid;grid-template-columns:200px 1fr;gap:32px;padding:32px 0;border-bottom:1px solid var(--border-light);align-items:start;">
            <div>
              <div style="font-size:16px;font-weight:600;color:var(--text-main);margin-bottom:4px;">{role.title}</div>
              <div style="font-size:11px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:8px;">{role.en}</div>
              <a href={role.href} style="font-size:13px;color:var(--accent-steel);">查看詳情（英文）→</a>
            </div>
            <div>
              <p style="font-size:15px;line-height:1.8;color:var(--text-secondary);margin-bottom:12px;">{role.desc}</p>
              <div style="font-size:12.5px;color:var(--text-muted);font-family:var(--font-mono);">基本要求：{role.req}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--bg-dark);">
    <div class="container">
      <div style="max-width:600px;">
        <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.45);margin-bottom:20px;">加入研究團隊</div>
        <h2 style="font-family:var(--font-serif);font-size:28px;color:#fff;margin-bottom:16px;font-weight:400;">申請加入全景研究院</h2>
        <p style="font-size:16px;color:rgba(255,255,255,0.65);line-height:1.75;margin-bottom:32px;">
          研究院歡迎來自全球各學科領域的學者申請研究員、副研究員及訪問學者職位。申請者須在研究院指定研究領域有明確的研究方向與研究計劃。
        </p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;">
          <a href="/collaboration/research-fellow-application"   class="btn btn-primary">申請研究員</a>
          <a href="/collaboration/visiting-scholar-application"  class="btn btn-secondary" style="color:#fff;border-color:rgba(255,255,255,0.3);">申請訪問學者</a>
          <a href="/people/join"                                 class="btn btn-secondary" style="color:#fff;border-color:rgba(255,255,255,0.3);">了解更多（英文）</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 768px) {
  div[style*="grid-template-columns:200px 1fr"] { display: block !important; }
}
</style>
