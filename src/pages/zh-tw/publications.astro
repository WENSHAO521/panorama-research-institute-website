---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout title="出版物" description="全景研究院的出版物，包括研究報告、工作論文、政策簡報及年度報告。" lang="zh-tw">
  <PageHero title="出版物" description="全景研究院的全部出版物均以開放獲取形式發布，並向Crossref註冊數位物件識別碼（DOI），永久免費提供給研究人員、機構及公眾。" breadcrumbs={[{ label: "出版物" }]} homeLabel="首頁" homeHref="/zh-tw" />

  <section class="section" style="background:var(--bg-white);">
    <div class="container">
      <div class="section-label">出版物類型</div>
      <div style="display:flex;flex-direction:column;gap:0;">
        {[
          { type:"研究報告", en:"研究報告", desc:"呈現原創研究成果的全長報告，採用嚴格的研究方法，經內部評審與外部同儕審查。研究報告是研究院最主要的知識貢獻形式，通常涵蓋文獻綜述、方法論、研究發現、政策含義及研究局限性。", href:"/publications/research-reports", length:"20,000–60,000字" },
          { type:"工作論文", en:"工作論文",     desc:"呈現初步研究發現、理論框架或學術論點的簡短學術文章，經內部編輯評審。工作論文是學術界分享前沿研究發現、徵集學術意見的重要形式，也是研究院快速傳播新研究思路的管道。", href:"/publications/working-papers", length:"5,000–15,000字" },
          { type:"政策簡報", en:"政策簡報",      desc:"基於證據的簡潔文件，向政策受眾呈現研究發現與建議，經內部編輯評審。政策簡報以結論為先，強調實際的政策建議，是研究院連接研究成果與政策實踐的重要橋樑。", href:"/publications/policy-briefs", length:"1,500–4,000字" },
          { type:"主編學術文集", en:"主編學術文集", desc:"多位學者圍繞特定主題合作撰寫的學術文集，由研究院與合作學術出版社聯合出版。文集通常由研究院學者擔任主編，徵集領域內的原創研究論文，通過同儕審查和編輯加工形成具有整體性的學術文集。", href:"/publications/edited-volumes", length:"多篇論文" },
          { type:"年度報告", en:"年度報告",     desc:"年度機構報告，全面記錄研究院每年的研究活動、出版物、學術活動、研究員項目及治理情況，並對未來一年的工作進行展望。年度報告是研究院履行透明度與問責制承諾的核心文件。", href:"/publications/annual-reports", length:"年度" },
          { type:"指南與標準", en:"指南與標準",       desc:"基於研究院研究成果開發、供期刊、出版社及學術機構參考使用的實用標準文件。這類出版物將研究成果轉化為可供實踐者直接參考的操作規範，是研究院連接學術研究與行業實踐的重要方式。", href:"/publications/guidelines", length:"視情況而定" },
        ].map((item) => (
          <div style="display:grid;grid-template-columns:200px 1fr 120px;gap:32px;padding:32px 0;border-bottom:1px solid var(--border-light);align-items:start;">
            <div>
              <div style="font-size:16px;font-weight:600;color:var(--text-main);margin-bottom:4px;">{item.type}</div>
              <div style="font-size:11px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:8px;">{item.en}</div>
              <div style="font-size:12px;color:var(--text-muted);">長度：{item.length}</div>
            </div>
            <p style="font-size:15px;line-height:1.8;color:var(--text-secondary);">{item.desc}</p>
            <div style="text-align:right;">
              <a href={item.href} style="font-size:13px;color:var(--accent-steel);">查看系列→</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-compact" style="background:var(--bg-main);border-top:1px solid var(--border-light);">
    <div class="container">
      <div style="max-width:720px;">
        <div class="section-label">引用格式</div>
        <h2 style="font-family:var(--font-serif);font-size:22px;color:var(--text-main);margin-bottom:16px;font-weight:400;">如何引用研究院出版物</h2>
        <div style="background:var(--bg-white);border:1px solid var(--border-light);padding:24px 28px;font-family:var(--font-mono);font-size:13.5px;line-height:1.7;color:var(--text-secondary);">
          Panorama Research Institute. (2026). <em>報告標題</em>. Panorama Scholarly Group.
        </div>
        <div style="margin-top:16px;">
          <a href="/publications/citation" class="btn btn-secondary">完整引用指南（英文）</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-compact" style="background:var(--bg-white);border-top:1px solid var(--border-light);">
    <div class="container">
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/publications/research-reports"  class="btn btn-primary">研究報告</a>
        <a href="/publications/working-papers"    class="btn btn-secondary">工作論文</a>
        <a href="/publications/policy-briefs"     class="btn btn-secondary">政策簡報</a>
        <a href="/publications/annual-reports"    class="btn btn-secondary">年度報告</a>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
@media (max-width: 768px) {
  div[style*="grid-template-columns:200px 1fr 120px"] { display: block !important; }
}
</style>
